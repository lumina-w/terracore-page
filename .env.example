# Google Analytics 4 — must use PUBLIC_ prefix to be available client-side
PUBLIC_GA_ID=G-XXXXXXXXXX

# Site URL — used for canonical/OG meta tags
PUBLIC_SITE_URL=https://terracoreapp.co

# WhatsApp contact number (with country code, no +)
CONTACT_WHATSAPP=573001234567

# Supabase — used by the #demo lead form (ContactForm.astro)
# Same project/credentials as luminaw.co, only adds the terracore_leads table
PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
PUBLIC_SUPABASE_ANON_KEY=eyJ...

# Brevo — used by /api/waitlist route (server-side)
# Prefer BREVO_API_KEY (no PUBLIC_ prefix) to avoid client exposure
BREVO_API_KEY=xkeysib-...
BREVO_LIST_ID=1
