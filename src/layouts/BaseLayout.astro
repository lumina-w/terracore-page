---
import '../styles/globals.css';
import Header from '@components/Header.astro';
import Footer from '@components/Footer.astro';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
}

const {
  title,
  description = 'TerraCore — Control total de tu operación agroindustrial en Colombia.',
  ogImage = '/og-image.png',
} = Astro.props;

const siteBase = Astro.site ?? 'https://terracoreapp.co';
const canonicalURL = new URL(Astro.url.pathname, siteBase);
const ogImageURL = new URL(ogImage, siteBase);
const gaId = import.meta.env.PUBLIC_GA_ID;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Inter:ital,opsz,wght@0,14..32,400;0,14..32,500;0,14..32,600;0,14..32,700;1,14..32,400&family=JetBrains+Mono:wght@400;500&family=Poppins:wght@400;700&display=swap"
    />

    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageURL} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="TerraCore" />
    <meta property="og:locale" content="es_CO" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageURL} />

    <title>{title}</title>

    <!-- Google Analytics 4 -->
    {gaId && (
      <>
        <script is:inline async src={`https://www.googletagmanager.com/gtag/js?id=${gaId}`}></script>
        <script is:inline define:vars={{ gaId }}>
          window.dataLayer = window.dataLayer || [];
          function gtag() { window.dataLayer.push(arguments); }
          gtag('js', new Date());
          gtag('config', gaId);
          window.trackEvent = function(name, params) { gtag('event', name, params || {}); };
        </script>
      </>
    )}

    <!-- Fallback: trackEvent no-op when GA not loaded -->
    {!gaId && (
      <script is:inline>window.trackEvent = function() {};</script>
    )}
  </head>
  <body>
    <Header />
    <slot />
    <Footer />
  </body>
</html>
