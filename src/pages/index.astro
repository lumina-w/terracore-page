---
import BaseLayout from '@layouts/BaseLayout.astro'

const ctaUrl = import.meta.env.MAIN_CTA_URL ?? '#'
---

<BaseLayout title="TerraCore — Gestión inteligente para tu negocio">
  <main class="min-h-screen flex flex-col items-center justify-center bg-background">
    <h1 class="text-4xl font-bold text-primary">TerraCore</h1>
    <p class="mt-4 text-lg text-text-main">Landing page en construcción.</p>
    <a
      href={ctaUrl}
      class="mt-8 px-6 py-3 bg-accent text-white font-semibold rounded-lg hover:opacity-90 transition-opacity"
    >
      Comenzar
    </a>
  </main>
</BaseLayout>
