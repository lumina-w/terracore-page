---
import BaseLayout from '@layouts/BaseLayout.astro';
import LandingTemplate from '@templates/LandingTemplate.astro';
import { FAQ } from '@utils/constants';

const jsonLd = JSON.stringify([
  {
    '@context': 'https://schema.org',
    '@type': 'Organization',
    name: 'TerraCore',
    url: 'https://terracoreapp.co',
    logo: 'https://terracoreapp.co/terracore.jpg',
    description:
      'TerraCore ayuda a productores y administradores de finca a reducir pérdidas, controlar costos y tomar decisiones con datos reales. Funciona sin internet. Diseñada para el campo colombiano.',
    address: {
      '@type': 'PostalAddress',
      addressRegion: 'Antioquia',
      addressCountry: 'CO',
    },
    contactPoint: {
      '@type': 'ContactPoint',
      telephone: '+57-310-828-3088',
      contactType: 'customer support',
      email: 'contact@luminaw.co',
      availableLanguage: 'Spanish',
    },
    sameAs: ['https://luminaw.co'],
  },
  {
    '@context': 'https://schema.org',
    '@type': 'WebSite',
    name: 'TerraCore',
    url: 'https://terracoreapp.co',
    description:
      'TerraCore ayuda a productores y administradores de finca a reducir pérdidas, controlar costos y tomar decisiones con datos reales. Funciona sin internet. Diseñada para el campo colombiano.',
    inLanguage: 'es-CO',
  },
  {
    '@context': 'https://schema.org',
    '@type': 'SoftwareApplication',
    name: 'TerraCore',
    applicationCategory: 'BusinessApplication',
    operatingSystem: 'Web, Android, iOS',
    url: 'https://terracoreapp.co',
    description:
      'Plataforma de gestión agroindustrial para reducir pérdidas, controlar costos y decidir con datos reales. Funciona sin internet.',
    inLanguage: 'es-CO',
  },
  {
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    inLanguage: 'es-CO',
    mainEntity: FAQ.map((item) => ({
      '@type': 'Question',
      name: item.q,
      acceptedAnswer: {
        '@type': 'Answer',
        text: item.a,
      },
    })),
  },
]);
---

<BaseLayout
  title="TerraCore | Menos pérdidas. Más control. Finca rentable."
  description="Reduce pérdidas, controla costos y decide con datos reales en tu finca. TerraCore funciona sin internet, diseñada para el campo colombiano."
  preloadImage="/screens/dashboard-2.webp"
>
  <script slot="head" is:inline type="application/ld+json" set:html={jsonLd} />
  <LandingTemplate />
</BaseLayout>
