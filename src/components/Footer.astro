---
import Brand from '@molecules/Brand.astro';
import { Icon } from 'astro-icon/components';
const ctaUrl = import.meta.env.MAIN_CTA_URL ?? 'https://calendly.com/wavival/30min';
---

<footer class="site-footer">
  <div class="container">
    <div class="foot-grid">
      <!-- Brand col -->
      <div>
        <div class="foot-logo-circle">
          <Brand mono size={28} />
        </div>
        <p class="foot-tagline">
          Plataforma de gestión agroindustrial diseñada para el campo colombiano. Hecha por Lúmina
          W.
        </p>
      </div>

      <!-- Producto -->
      <div>
        <h5 class="foot-col-title">Producto</h5>
        <ul class="foot-links">
          <li><a href="#modulos">Módulos</a></li>
          <li><a href="#producto">Capturas</a></li>
          <li><a href="#precios">Precios</a></li>
          <li><a href="#preguntas">Preguntas</a></li>
        </ul>
      </div>

      <!-- Compañía -->
      <div>
        <h5 class="foot-col-title">Compañía</h5>
        <ul class="foot-links">
          <li><a href="https://luminaw.co" target="_blank" rel="noopener">Sobre Lúmina W</a></li>
          <li><a href="mailto:hola@terracoreapp.co">Contacto</a></li>
        </ul>
      </div>

      <!-- Contacto -->
      <div>
        <h5 class="foot-col-title">Contacto</h5>
        <ul class="foot-links foot-links--contact">
          <li>
            <Icon name="lucide:mail" width={20} height={20} />
            <a href="mailto:hola@terracoreapp.co">hola@terracoreapp.co</a>
          </li>
          <li>
            <Icon name="lucide:phone" width={20} height={20} />
            <a href="tel:+573108283088">+57 310 828 3088</a>
          </li>
          <li>
            <svg
              width={20}
              height={20}
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="1.6"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"
            >
              <path d="M3 21l1.6-5A8 8 0 1 1 8 19.4z"></path>
              <path d="M9 10c.3 1.5 1.2 2.8 2.5 3.7M14 14c-1 0-1-1-2-1"></path>
            </svg>
            <a href="https://wa.me/573108283088" target="_blank" rel="noopener">WhatsApp</a>
          </li>
          <li>
            <Icon name="lucide:map-pin" width={20} height={20} />
            Antioquia, Colombia
          </li>
        </ul>
      </div>
    </div>

    <!-- CTA strip -->
    <div class="foot-cta">
      <p class="foot-cta-text">¿Listo para ordenar tu operación?</p>
      <a href={ctaUrl} class="foot-cta-btn" target="_blank" rel="noopener">Agendar demo</a>
    </div>

    <div class="foot-bottom">
      <span>© 2026 TerraCore · Lúmina W. Todos los derechos reservados.</span>
      <span class="foot-legal">
        <a href="/terminos">Términos</a>
        <a href="/privacidad">Privacidad</a>
        <a href="/habeas-data">Habeas Data</a>
      </span>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    background: var(--color-primary-active);
    color: rgba(255, 255, 255, 0.65);
    padding: 64px 0 32px;
  }

  .foot-grid {
    display: grid;
    grid-template-columns: 1.4fr 1fr 1fr 1fr;
    gap: 48px;
    margin-bottom: 40px;
  }
  @media (max-width: 880px) {
    .foot-grid {
      grid-template-columns: 1fr 1fr;
      gap: 32px;
    }
  }
  @media (max-width: 540px) {
    .foot-grid {
      grid-template-columns: 1fr;
    }
  }

  .foot-logo-circle {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 56px;
    height: 56px;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.07);
    border: 1px solid rgba(255, 255, 255, 0.12);
  }

  .foot-tagline {
    font-size: 14px;
    line-height: 22px;
    max-width: 32ch;
    margin: 16px 0 0;
    color: rgba(255, 255, 255, 0.65);
  }

  /* CTA strip */
  .foot-cta {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 24px;
    flex-wrap: wrap;
    border-top: 1px solid rgba(255, 255, 255, 0.08);
    border-bottom: 1px solid rgba(255, 255, 255, 0.08);
    padding: 32px 0;
    margin-bottom: 32px;
  }
  .foot-cta-text {
    font-size: 18px;
    font-weight: 600;
    color: #fff;
    margin: 0;
  }
  .foot-cta-btn {
    background: var(--color-accent);
    color: #fff;
    border-radius: 8px;
    padding: 12px 24px;
    font-size: 14px;
    font-weight: 700;
    text-decoration: none;
    transition: background var(--dur-base) var(--ease-standard);
    white-space: nowrap;
  }
  .foot-cta-btn:hover {
    background: var(--color-accent-hover);
    color: #fff;
  }

  /* Column titles */
  .foot-col-title {
    font-size: 11px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.5);
    margin: 0 0 16px;
    font-weight: 600;
  }

  /* Links */
  .foot-links {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 10px;
    font-size: 14px;
    color: rgba(255, 255, 255, 0.65);
  }
  .foot-links a:hover {
    color: #fff;
  }
  .foot-links--contact li {
    display: flex;
    align-items: center;
    gap: 8px;
  }
  .foot-links--contact a {
    color: inherit;
    text-decoration: none;
  }
  .foot-links--contact a:hover {
    color: #fff;
  }

  /* Bottom bar */
  .foot-bottom {
    border-top: 1px solid rgba(255, 255, 255, 0.08);
    padding-top: 24px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-size: 12px;
    flex-wrap: wrap;
    gap: 12px;
  }
  .foot-legal {
    display: flex;
    gap: 16px;
  }
  .foot-legal a:hover {
    color: #fff;
  }
</style>
