---
const year = new Date().getFullYear()
---

<footer class="border-t border-border bg-background">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-8 flex flex-col sm:flex-row items-center justify-between gap-4">

    <a href="/" class="font-bold text-lg text-primary" aria-label="TerraCore">TerraCore</a>

    <p class="text-sm text-muted-foreground order-last sm:order-none">
      © {year} Lúmina W. Todos los derechos reservados.
    </p>

    <nav aria-label="Navegación de pie de página">
      <ul class="flex gap-6 text-sm">
        <li>
          <a href="/privacy" class="text-muted-foreground hover:text-foreground transition-colors duration-fast">
            Privacidad
          </a>
        </li>
        <li>
          <a href="/terms" class="text-muted-foreground hover:text-foreground transition-colors duration-fast">
            Términos
          </a>
        </li>
      </ul>
    </nav>
  </div>
</footer>
