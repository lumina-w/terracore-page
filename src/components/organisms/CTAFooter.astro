---
import ContactForm from '@components/ContactForm.astro';
---

<section class="cta-band reveal" id="demo">
  <div class="container">
    <div class="cta-card marker-corners" style="color:rgba(255,255,255,0.4)">
      <div class="cta-inner">
        <h2 class="cta-card__heading">
          Descubre cuánto estás perdiendo sin saberlo.<br /><span class="accent-line"
            >En 30 minutos te mostramos el impacto real para tu operación.</span
          >
        </h2>
        <p class="cta-card__desc">
          Déjanos tus datos y te mostramos TerraCore con datos de fincas reales. Sesión de
          diagnóstico de 30 minutos, sin compromiso.
        </p>

        <ol class="steps-strip">
          <li>
            <span class="step-num">01</span>
            <span class="step-txt">Confirmación inmediata</span>
          </li>
          <li>
            <span class="step-num">02</span>
            <span class="step-txt">WhatsApp en menos de 24h hábiles</span>
          </li>
          <li>
            <span class="step-num">03</span>
            <span class="step-txt">Diagnóstico de 30 min sin costo</span>
          </li>
          <li>
            <span class="step-num">04</span>
            <span class="step-txt">Si encaja, arrancamos esa semana</span>
          </li>
        </ol>

        <div class="form-card">
          <ContactForm />
        </div>

        <p class="cta-foot">Sin compromiso. Sin presión de venta.</p>
      </div>
    </div>
  </div>
</section>

<script>
  const strip = document.querySelector('.steps-strip');
  if (strip) {
    const observer = new IntersectionObserver(
      ([entry]) => {
        if (entry.isIntersecting) {
          strip.classList.add('steps-strip--visible');
          observer.disconnect();
        }
      },
      { threshold: 0.4 },
    );
    observer.observe(strip);
  }
</script>

<style>
  .accent-line {
    color: var(--color-accent);
  }

  .cta-band {
    background: var(--color-bg);
    padding: 96px 0;
  }

  .cta-card {
    background: var(--color-primary-active);
    border-radius: 20px;
    padding: 72px 64px;
    color: #fff;
    position: relative;
    overflow: hidden;
  }
  .cta-card::before {
    content: '';
    position: absolute;
    inset: 0;
    background:
      radial-gradient(600px 420px at 50% 0%, rgba(217, 119, 6, 0.3), transparent 62%),
      radial-gradient(700px 500px at 50% 100%, rgba(60, 117, 86, 0.45), transparent 60%);
    pointer-events: none;
  }
  .cta-card > * {
    position: relative;
  }

  /* Centered single column */
  .cta-inner {
    max-width: 820px;
    margin: 0 auto;
    text-align: center;
  }

  .cta-card__heading {
    color: #fff;
    font-family: var(--font-display);
    font-size: clamp(30px, 3.6vw, 46px);
    font-weight: 700;
    letter-spacing: -0.025em;
    line-height: 1.07;
    margin: 0 0 16px;
    text-wrap: balance;
  }
  .cta-card__desc {
    color: rgba(255, 255, 255, 0.78);
    font-size: 17px;
    line-height: 26px;
    max-width: 52ch;
    margin: 0 auto 36px;
  }

  /* ── Steps strip (horizontal) ── */
  .steps-strip {
    list-style: none;
    padding: 0;
    margin: 0 0 36px;
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 18px;
    counter-reset: none;
  }
  .steps-strip li {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 10px;
    font-size: 13px;
    font-weight: 500;
    line-height: 1.35;
    color: rgba(255, 255, 255, 0.85);
    opacity: 0;
    transform: translateY(10px);
    transition:
      opacity 0.4s ease,
      transform 0.4s ease;
  }
  .step-num {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 34px;
    height: 34px;
    border-radius: 50%;
    background: rgba(217, 119, 6, 0.18);
    border: 1px solid rgba(217, 119, 6, 0.4);
    color: var(--color-accent);
    font-family: var(--font-mono);
    font-size: 13px;
    font-weight: 700;
    flex: 0 0 auto;
    transform: scale(0);
    transition: transform 0.35s cubic-bezier(0.34, 1.56, 0.64, 1);
  }
  .step-txt {
    max-width: 16ch;
  }

  .steps-strip--visible li {
    opacity: 1;
    transform: none;
  }
  .steps-strip--visible li:nth-child(1) {
    transition-delay: 0ms;
  }
  .steps-strip--visible li:nth-child(2) {
    transition-delay: 120ms;
  }
  .steps-strip--visible li:nth-child(3) {
    transition-delay: 240ms;
  }
  .steps-strip--visible li:nth-child(4) {
    transition-delay: 360ms;
  }
  .steps-strip--visible li:nth-child(1) .step-num {
    transform: scale(1);
    transition-delay: 60ms;
  }
  .steps-strip--visible li:nth-child(2) .step-num {
    transform: scale(1);
    transition-delay: 180ms;
  }
  .steps-strip--visible li:nth-child(3) .step-num {
    transform: scale(1);
    transition-delay: 300ms;
  }
  .steps-strip--visible li:nth-child(4) .step-num {
    transform: scale(1);
    transition-delay: 420ms;
  }

  /* ── Form card ── */
  .form-card {
    max-width: 560px;
    margin: 0 auto;
    background: rgba(0, 0, 0, 0.2);
    border: 1px solid rgba(255, 255, 255, 0.16);
    border-radius: 16px;
    padding: 32px;
    text-align: left;
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.08),
      0 12px 40px rgba(0, 0, 0, 0.18);
  }
  .form-card :global(.lead) {
    max-width: none;
  }
  /* Wider form on tablet + desktop, capped so it never exceeds 70% of
     the viewport (and an absolute ceiling for very large screens) */
  @media (min-width: 768px) {
    .form-card {
      width: clamp(560px, 70vw, 760px);
      max-width: none;
    }
  }

  .cta-foot {
    margin: 22px 0 0;
    font-size: 13px;
    font-weight: 500;
    color: rgba(255, 255, 255, 0.6);
  }

  @media (max-width: 720px) {
    .cta-band {
      padding: 64px 0;
    }
    .cta-card {
      padding: 44px 24px;
    }
    .steps-strip {
      grid-template-columns: repeat(2, 1fr);
      gap: 22px 14px;
    }
    .form-card {
      padding: 24px 20px;
    }
  }
</style>
