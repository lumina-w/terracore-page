---
import Eyebrow from '@atoms/Eyebrow.astro';
import { Icon } from 'astro-icon/components';

type Cell = string | { text: string; badge: 'ok' | 'warn' | 'error' };
const modules: Array<{
  num: string;
  name: string;
  icon: string;
  desc: string;
  table: { cols: string[]; rows: Cell[][] };
}> = [
  {
    num: '02',
    name: 'Nunca más pierdas un animal por falta de historial',
    icon: 'lucide:paw-print',
    desc: 'Sabe exactamente en qué estado está cada animal: peso, salud, ubicación e historial. Sin depender de la memoria del mayordomo ni de cuadernos que se pierden.',
    table: {
      cols: ['ID', 'Nombre', 'Raza', 'Peso', 'Ubicación'],
      rows: [
        ['ANI-001', 'La Canela', 'Brahman', '480 kg', 'Potrero Norte'],
        ['ANI-002', 'Estrella', 'Holstein', '512 kg', 'Corral 2'],
        ['ANI-003', 'El Rocío', 'Cebú', '390 kg', 'Potrero Sur'],
      ],
    },
  },
  {
    num: '03',
    name: 'Deja de correr: sabe qué se acaba antes de que se acabe',
    icon: 'lucide:package',
    desc: 'TerraCore te avisa antes de que se acabe el concentrado o venza la vacuna. Menos corridas de último momento, menos plata perdida en compras urgentes, menos animales sin atención.',
    table: {
      cols: ['Nombre', 'Categoría', 'Cantidad', 'Mínimo', 'Proveedor'],
      rows: [
        ['Concentrado Lechero', 'Alimentación', '340 kg', '200 kg', 'Agroveterinaria Urabá'],
        ['Vacuna Triple Bovina', 'Sanidad', '18 dosis', '10 dosis', 'Vetco Colombia'],
        ['Sal Mineralizada', 'Suplemento', '85 kg', '50 kg', 'Nutril Agro'],
      ],
    },
  },
  {
    num: '04',
    name: 'Una aspersora dañada en fumigación cuesta más que el plan anual',
    icon: 'lucide:wrench',
    desc: 'Registra el estado de cada equipo y programa el mantenimiento antes de que falle. Una aspersora dañada en época de fumigación cuesta más que cualquier plan.',
    table: {
      cols: ['Nombre', 'Condición', 'Notas'],
      rows: [
        ['Aspersora 20 L', 'Buena', 'Lista para uso'],
        ['Báscula ganadera', 'Buena', 'Calibrada'],
        ['Bomba de agua 2HP', 'Regular', 'Revisar sello'],
      ],
    },
  },
  {
    num: '05',
    name: 'Descubre qué parte de tu finca pone y qué parte pierde',
    icon: 'lucide:bar-chart-2',
    desc: 'Registra cada lote con sus insumos y horas invertidas. Con el tiempo, TerraCore te muestra qué produce más, qué cuesta más y dónde está el margen real de tu operación.',
    table: {
      cols: ['Lote', 'Producto', 'Cantidad', 'Insumos'],
      rows: [
        ['PRD-041', 'Leche cruda', '380 L', 'Concentrado 12 kg'],
        ['PRD-042', 'Leche cruda', '362 L', 'Concentrado 12 kg'],
        ['PRD-043', 'Leche cruda', '395 L', 'Concentrado 14 kg'],
      ],
    },
  },
];
---

<section class="section-pad reveal" id="modulos">
  <div class="container">
    <div class="section-head">
      <div>
        <Eyebrow num="01">Producto</Eyebrow>
        <h2 class="display lg" style="margin-top:16px">
          Todo lo que necesitas para <span class="accent-text">operar mejor y perder menos</span>.
        </h2>
      </div>
      <p class="lead">
        Inventario, producción, salud animal y finanzas en un solo lugar. Cuando algo cambia en un
        lado, todo el sistema se actualiza solo, y funciona sin conexión: registra en el campo y
        sincroniza cuando vuelve la señal.
      </p>
    </div>

    <div class="bento">
      <!-- Featured: Dashboard -->
      <div class="bento-tile bento-tile--featured">
        <div>
          <div class="bento-tile__header">
            <div class="bento-tile__icon-sq">
              <Icon name="lucide:layout-dashboard" width={22} height={22} />
            </div>
            <h3 class="bento-tile__name">Opera con información real, no con suposiciones</h3>
          </div>
          <p class="bento-tile__desc">
            Sabe qué está pasando en tu finca antes de salir de la casa. Animales activos, alertas
            urgentes, producción del mes y costos, todo en una sola pantalla para tomar decisiones
            con información real, no con memoria.
          </p>
        </div>
        <div class="demo-mini">
          <div class="demo-mini__stat">
            <Icon name="lucide:paw-print" width={48} height={48} class="kpi-icon" />
            <div class="demo-mini__text">
              <div class="demo-mini__val">88</div>
              <div class="demo-mini__label">Animales activos</div>
              <div class="demo-mini__sub">en finca</div>
            </div>
          </div>
          <div class="demo-mini__stat">
            <Icon name="lucide:droplets" width={48} height={48} class="kpi-icon" />
            <div class="demo-mini__text">
              <div class="demo-mini__val">3.202</div>
              <div class="demo-mini__label">Producción mensual</div>
              <div class="demo-mini__sub">unidades este mes</div>
            </div>
          </div>
          <div class="demo-mini__stat">
            <Icon name="lucide:package" width={48} height={48} class="kpi-icon" />
            <div class="demo-mini__text">
              <div class="demo-mini__val">9.274</div>
              <div class="demo-mini__label">Insumos disponibles</div>
              <div class="demo-mini__sub">en stock total</div>
            </div>
          </div>
          <div class="demo-mini__stat">
            <Icon
              name="lucide:alert-triangle"
              width={48}
              height={48}
              class="kpi-icon kpi-icon--accent"
            />
            <div class="demo-mini__text">
              <div class="demo-mini__val demo-mini__val--accent">6</div>
              <div class="demo-mini__label">Alertas stock bajo</div>
              <div class="demo-mini__sub">requieren atención</div>
            </div>
          </div>
        </div>
      </div>

      <!-- Standard module tiles -->
      {
        modules.map((m) => (
          <div class:list={['bento-tile', m.num === '05' && 'bento-tile--span4']}>
            <div>
              <div class="bento-tile__header">
                <div class="bento-tile__icon-sq">
                  <Icon name={m.icon} width={22} height={22} />
                </div>
                <h3 class="bento-tile__name">{m.name}</h3>
              </div>
              <p class="bento-tile__desc">{m.desc}</p>
            </div>
            <div class="bento-preview">
              <table class="mini-table">
                <thead>
                  <tr>
                    {m.table.cols.map((col) => (
                      <th>{col}</th>
                    ))}
                  </tr>
                </thead>
                <tbody>
                  {m.table.rows.map((row) => (
                    <tr>
                      {row.map((cell) =>
                        typeof cell === 'string' ? (
                          <td>{cell}</td>
                        ) : (
                          <td>
                            <span class={`badge badge--${cell.badge}`}>{cell.text}</span>
                          </td>
                        ),
                      )}
                    </tr>
                  ))}
                </tbody>
              </table>
            </div>
          </div>
        ))
      }

      <!-- Salud Animal — sub-tabs -->
      <div class="bento-tile bento-tile--wide bento-tile--salud">
        <div>
          <div class="bento-tile__header">
            <div class="bento-tile__icon-sq">
              <Icon name="lucide:stethoscope" width={22} height={22} />
            </div>
            <h3 class="bento-tile__name">
              Prevenir un brote vale más que cualquier tratamiento de emergencia
            </h3>
          </div>
          <p class="bento-tile__desc">
            Vacunas vencidas, alertas próximas y estado sanitario de cada animal. Prevenir una
            muerte o un brote vale más que cualquier tratamiento de emergencia.
          </p>
        </div>
        <div class="bento-preview">
          <table class="mini-table">
            <thead><tr><th>Animal</th><th>Vacuna</th><th>Fecha</th><th>Veterinario</th></tr></thead>
            <tbody>
              <tr
                ><td>La Canela</td><td>Triple Bovina</td><td>15 abr 2026</td><td>Dr. Ramírez</td
                ></tr
              >
              <tr><td>Estrella</td><td>Aftosa</td><td>20 abr 2026</td><td>Dr. Ramírez</td></tr>
              <tr><td>El Rocío</td><td>Brucelosis</td><td>28 feb 2026</td><td>Dr. Ramírez</td></tr>
            </tbody>
          </table>
        </div>
      </div>

      <!-- Wide integration tile -->
      <div class="bento-tile bento-tile--wide bento-integration">
        <div class="bento-integration__copy">
          <Eyebrow num="07">Integrado</Eyebrow>
          <h3 class="bento-integration__title">Una acción. Todo el sistema al día.</h3>
          <p class="bento-integration__desc">
            Los módulos no son aislados: cuando aplicas un tratamiento, TerraCore descuenta el
            insumo, agenda el refuerzo y actualiza el estado de salud del animal. Una acción, todo
            el sistema al día. Así eliminas el doble trabajo, los errores de transcripción y la
            información que vive en la cabeza de una sola persona.
          </p>
        </div>
        <div class="bento-integration__flow">
          <div class="flow-card">
            <div class="flow-row flow-row--success">
              <Icon name="lucide:check" width={14} height={14} />
              Vacuna aplicada · Triple Bovina
            </div>
            <div class="flow-arrow">↓</div>
            <div class="flow-row flow-row--dashed">
              <span>Insumo descontado</span>
              <span class="flow-row__val">−1 dosis</span>
            </div>
            <div class="flow-row flow-row--dashed">
              <span>Próximo refuerzo</span>
              <span class="flow-row__val">14 may</span>
            </div>
          </div>

          <div class="flow-card">
            <div class="flow-row flow-row--success">
              <Icon name="lucide:package" width={14} height={14} />
              Insumo en stock mínimo
            </div>
            <div class="flow-arrow">↓</div>
            <div class="flow-row flow-row--dashed">
              <span>Alerta automática al administrador</span>
            </div>
            <div class="flow-row flow-row--dashed">
              <span>Pedido programado sin urgencia</span>
            </div>
          </div>

          <div class="flow-card">
            <div class="flow-row flow-row--success">
              <Icon name="lucide:sprout" width={14} height={14} />
              Producción registrada
            </div>
            <div class="flow-arrow">↓</div>
            <div class="flow-row flow-row--dashed">
              <span>Costo por lote calculado</span>
            </div>
            <div class="flow-row flow-row--dashed">
              <span>Rentabilidad visible en el dashboard</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .accent-text {
    color: var(--color-text-link);
  }

  #modulos .section-head {
    grid-template-columns: 1fr;
    gap: 16px;
    align-items: start;
  }

  /* ── Bento grid ────────────────────────────────────────────── */
  .bento {
    display: grid;
    grid-template-columns: repeat(6, 1fr);
    grid-auto-rows: minmax(220px, auto);
    gap: 16px;
  }

  .bento-tile {
    position: relative;
    grid-column: span 2;
    border-radius: 14px;
    padding: 28px;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    overflow: hidden;
    transition: all 220ms var(--ease-standard);
  }
  .bento-tile:hover {
    border-color: var(--color-border-strong);
    transform: translateY(-2px);
    box-shadow: var(--shadow-md);
  }

  .bento-tile__num {
    position: absolute;
    top: 20px;
    right: 24px;
    font-family: var(--font-display);
    font-size: 14px;
    font-variant-numeric: tabular-nums;
    letter-spacing: 0.06em;
    color: var(--color-text-muted);
    font-weight: 500;
  }

  .bento-tile__header {
    display: flex;
    flex-direction: row;
    align-items: center;
    gap: 12px;
    margin-bottom: 12px;
  }
  .bento-tile__icon-sq {
    width: 44px;
    height: 44px;
    border-radius: 10px;
    background: var(--color-primary);
    color: #fff;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .bento-tile__name {
    font-family: var(--font-display);
    font-size: 24px;
    line-height: 1.3;
    letter-spacing: -0.015em;
    font-weight: 700;
    margin: 0 0 8px;
    color: var(--color-text);
  }
  .bento-tile__desc {
    font-size: 14px;
    line-height: 22px;
    color: var(--color-text-secondary);
    margin: 0;
  }

  /* Featured tile */
  .bento-tile--featured {
    grid-column: span 4;
    grid-row: span 2;
    background: var(--color-primary-active);
    color: #fff;
    border-color: var(--color-primary-active);
    padding: 36px;
  }
  .bento-tile--featured::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(420px 320px at 100% 0%, rgba(217, 119, 6, 0.32), transparent 60%);
    pointer-events: none;
  }
  .bento-tile--featured .bento-tile__icon-sq {
    background: var(--color-accent);
  }
  .bento-tile--featured .bento-tile__name {
    color: #fff;
    font-size: 36px;
  }
  .bento-tile--featured .bento-tile__desc {
    color: rgba(255, 255, 255, 0.78);
    font-size: 16px;
    line-height: 26px;
  }
  .bento-tile--featured .bento-tile__num {
    color: rgba(255, 255, 255, 0.6);
  }

  /* Wide tile */
  .bento-tile--wide {
    grid-column: span 6;
  }

  /* Span-4 tile (varied rhythm) */
  .bento-tile--span4 {
    grid-column: span 4;
  }

  /* Salud: full-width, copy + table side by side */
  .bento-tile--salud {
    display: grid;
    grid-template-columns: 1fr 1.25fr;
    gap: 32px;
    align-items: center;
  }
  .bento-tile--salud .bento-preview {
    margin-top: 0;
  }

  /* Demo mini widget */
  .demo-mini {
    margin-top: 20px;
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid rgba(255, 255, 255, 0.12);
    border-radius: 10px;
    padding: 20px;
    display: flex;
    flex-wrap: wrap;
    gap: 24px 16px;
    justify-content: center;
  }
  .demo-mini__stat {
    flex: 1 1 calc(33.33% - 32px);
    min-width: 140px;
    display: flex;
    flex-direction: row;
    align-items: center;
    gap: 12px;
  }
  .demo-mini__text {
    display: flex;
    flex-direction: column;
  }
  @media (max-width: 520px) {
    .demo-mini__stat {
      flex: 1 1 100%;
    }
  }
  .kpi-icon {
    flex-shrink: 0;
    color: rgba(255, 255, 255, 0.7);
  }
  .kpi-icon--accent {
    color: var(--color-accent);
  }
  .demo-mini__label {
    font-size: 10px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.6);
    margin-bottom: 6px;
  }
  .demo-mini__val {
    font-family: var(--font-display);
    font-size: 18px;
    font-weight: 700;
    font-variant-numeric: tabular-nums;
    color: #fff;
    line-height: 1.2;
  }
  .demo-mini__val--accent {
    color: var(--color-accent-on-dark);
  }
  .demo-mini__sub {
    font-size: 9px;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.62);
    margin-top: 2px;
  }

  /* Integration wide tile */
  .bento-integration {
    display: grid !important;
    grid-template-columns: 1.4fr 1fr;
    gap: 32px;
    align-items: center;
    background: var(--color-bg) !important;
    padding: 32px 36px !important;
  }
  .bento-integration:hover {
    transform: none !important;
  }

  .bento-integration__title {
    font-family: var(--font-display);
    font-size: 24px;
    font-weight: 700;
    letter-spacing: -0.015em;
    color: var(--color-text);
    margin: 12px 0 8px;
  }
  .bento-integration__desc {
    font-size: 14px;
    line-height: 22px;
    color: var(--color-text-secondary);
  }

  .bento-integration__flow {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }
  .flow-card {
    background: #fff;
    border: 1px solid var(--color-border);
    border-radius: 10px;
    padding: 16px;
    font-size: 13px;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  .flow-row {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 8px 10px;
    border-radius: 6px;
  }
  .flow-row--success {
    background: var(--color-success-bg);
    color: var(--color-success-fg);
    font-weight: 600;
  }
  .flow-row--dashed {
    background: var(--color-bg);
    border: 1px dashed var(--color-border-strong);
    justify-content: space-between;
    color: var(--color-text);
  }
  .flow-row__val {
    font-variant-numeric: tabular-nums;
    color: var(--color-text-muted);
  }
  .flow-arrow {
    padding-left: 14px;
    color: var(--color-text-secondary);
    font-size: 12px;
  }

  /* Mini preview table */
  .bento-preview {
    margin-top: 16px;
    border: 1px solid var(--color-border);
    border-radius: 8px;
    overflow-x: auto;
    overflow-y: hidden;
    font-size: 11px;
    scrollbar-width: thin;
    scrollbar-color: var(--color-primary) transparent;
  }
  .bento-preview::-webkit-scrollbar {
    height: 4px;
  }
  .bento-preview::-webkit-scrollbar-track {
    background: transparent;
  }
  .bento-preview::-webkit-scrollbar-thumb {
    background: var(--color-primary);
    border-radius: 2px;
  }
  .mini-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 11px;
  }
  .mini-table th {
    padding: 5px 8px;
    text-align: left;
    font-size: 9px;
    letter-spacing: 0.07em;
    text-transform: uppercase;
    color: var(--color-text-muted);
    font-weight: 600;
    border-bottom: 1px solid var(--color-border);
    background: var(--color-bg);
  }
  .mini-table td {
    padding: 5px 8px;
    color: var(--color-text-secondary);
    border-bottom: 1px solid var(--color-border);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    max-width: 120px;
  }
  .mini-table tr:last-child td {
    border-bottom: none;
  }
  .mini-table td:first-child {
    color: var(--color-text);
    font-weight: 500;
    font-variant-numeric: tabular-nums;
  }
  .badge {
    display: inline-flex;
    align-items: center;
    padding: 2px 6px;
    border-radius: 4px;
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 0.03em;
  }
  .badge--ok {
    background: var(--color-success-bg);
    color: var(--color-success-fg);
  }
  .badge--warn {
    background: rgba(217, 119, 6, 0.12);
    color: var(--color-accent-active);
  }
  .badge--error {
    background: rgba(220, 38, 38, 0.1);
    color: #dc2626;
  }
  /* Animal info ficha */
  .animal-info {
    padding: 4px 0;
  }
  .animal-info__row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 4px 8px;
    border-bottom: 1px solid var(--color-border);
    font-size: 11px;
    gap: 8px;
  }
  .animal-info__row:last-child {
    border-bottom: none;
  }
  .animal-info__key {
    color: var(--color-text-muted);
    font-size: 9px;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    font-weight: 600;
    flex-shrink: 0;
  }

  /* Responsive */
  @media (max-width: 1024px) {
    .bento {
      grid-template-columns: repeat(2, 1fr);
    }
    .bento-tile,
    .bento-tile--featured,
    .bento-tile--wide,
    .bento-tile--span4 {
      grid-column: span 2;
      grid-row: auto;
    }
    .bento-tile--salud {
      display: flex;
    }
    .bento-tile--featured .bento-tile__name {
      font-size: 28px;
    }
    .bento-integration {
      grid-template-columns: 1fr;
    }
  }
  @media (max-width: 600px) {
    .bento {
      grid-template-columns: 1fr;
    }
    .bento-tile {
      grid-column: span 1 !important;
    }
  }
</style>
