---
import Eyebrow from '@atoms/Eyebrow.astro';

const tabData = [
  {
    id: 'dashboard',
    label: 'Dashboard',
    images: ['/screens/dashboard-1.webp', '/screens/dashboard-2.webp'],
  },
  {
    id: 'animales',
    label: 'Animales',
    images: ['/screens/animales-1.webp', '/screens/animales-2.webp', '/screens/animales-3.webp'],
  },
  {
    id: 'insumos',
    label: 'Insumos',
    images: [
      '/screens/insumos-1.webp',
      '/screens/insumos-2.webp',
      '/screens/insumos-3.webp',
      '/screens/insumos-4.webp',
      '/screens/insumos-5.webp',
    ],
  },
  {
    id: 'produccion',
    label: 'Producción',
    images: [
      '/screens/produccion-1.webp',
      '/screens/produccion-2.webp',
      '/screens/produccion-3.webp',
      '/screens/produccion-4.webp',
    ],
  },
  {
    id: 'salud',
    label: 'Salud Animal',
    images: [
      '/screens/salud-animal-1.webp',
      '/screens/salud-animal-2.webp',
      '/screens/salud-animal-3.webp',
      '/screens/salud-animal-4.webp',
      '/screens/salud-animal-5.webp',
      '/screens/salud-animal-6.webp',
    ],
  },
];
---

<section class="showcase reveal" id="producto">
  <div class="showcase__bg" aria-hidden="true"></div>
  <div class="container" style="position:relative">
    <div class="section-head" style="margin-bottom:24px">
      <div>
        <Eyebrow num="02" onDark>El producto</Eyebrow>
        <h2 class="display lg showcase__heading">
          Tan fácil de usar como un cuaderno.<br /><span class="accent">Mucho más poderoso.</span>
        </h2>
      </div>
      <p class="lead showcase__lead">
        Pensado para usarse con guantes, con mala luz y con afán. Desde el celular en el corral hasta
        el computador del administrador: la misma información, siempre disponible.
      </p>
    </div>

    <!-- Tabs -->
    <div class="showcase-tabs" role="tablist" aria-label="Capturas del producto">
      {
        tabData.map((t, i) => (
          <button
            class:list={['showcase-tab', i === 0 && 'active']}
            role="tab"
            aria-selected={i === 0 ? 'true' : 'false'}
            aria-controls={`panel-${t.id}`}
            data-tab={t.id}
          >
            {t.label}
          </button>
        ))
      }
    </div>

    <!-- Image frame -->
    <div class="showcase-frame" id="showcase-frame" role="tabpanel" id="panel-dashboard">
      <img
        id="showcase-img"
        class="showcase-img is-active"
        src={tabData[0]!.images[0]}
        alt={`TerraCore | ${tabData[0]!.label}`}
        width="1200"
        height="750"
        loading="lazy"
        decoding="async"
      />
      <img
        class="showcase-img"
        width="1200"
        height="750"
        alt=""
        aria-hidden="true"
        decoding="async"
      />
    </div>

    <!-- Dots -->
    <div class="showcase-dots" id="showcase-dots" aria-hidden="true"></div>

    <!-- Callouts -->
    <div class="showcase-callouts">
      <div class="showcase-callout">
        <div class="showcase-callout__num">01</div>
        <h4 class="showcase-callout__title">Todo donde lo necesitas</h4>
        <p class="showcase-callout__desc">
          La información que usas todos los días a un toque. Sin menús confusos, sin pasos de más.
        </p>
      </div>
      <div class="showcase-callout">
        <div class="showcase-callout__num">02</div>
        <h4 class="showcase-callout__title">Legible en cualquier condición</h4>
        <p class="showcase-callout__desc">
          Texto grande, colores con significado, respuesta rápida. Funciona igual bajo el sol que en
          la oficina.
        </p>
      </div>
      <div class="showcase-callout">
        <div class="showcase-callout__num">03</div>
        <h4 class="showcase-callout__title">Solo te avisamos cuando importa</h4>
        <p class="showcase-callout__desc">
          Vacunas vencidas, stock bajo, animales en tratamiento. Cada alerta es una pérdida que se
          puede evitar.
        </p>
      </div>
    </div>
  </div>
</section>

<script>
  const TABS: Record<string, string[]> = {
    dashboard: ['/screens/dashboard-1.webp', '/screens/dashboard-2.webp'],
    animales: ['/screens/animales-1.webp', '/screens/animales-2.webp', '/screens/animales-3.webp'],
    insumos: [
      '/screens/insumos-1.webp',
      '/screens/insumos-2.webp',
      '/screens/insumos-3.webp',
      '/screens/insumos-4.webp',
      '/screens/insumos-5.webp',
    ],
    produccion: [
      '/screens/produccion-1.webp',
      '/screens/produccion-2.webp',
      '/screens/produccion-3.webp',
      '/screens/produccion-4.webp',
    ],
    salud: [
      '/screens/salud-animal-1.webp',
      '/screens/salud-animal-2.webp',
      '/screens/salud-animal-3.webp',
      '/screens/salud-animal-4.webp',
      '/screens/salud-animal-5.webp',
      '/screens/salud-animal-6.webp',
    ],
  };

  const INTERVAL = 3000;

  const tabBtns = document.querySelectorAll<HTMLButtonElement>('.showcase-tab');
  const frame = document.getElementById('showcase-frame')!;
  const layers = [...frame.querySelectorAll<HTMLImageElement>('.showcase-img')];
  const dotsEl = document.getElementById('showcase-dots')!;

  let activeTab = 'dashboard';
  let slideIdx = 0;
  let timerId: ReturnType<typeof setInterval> | null = null;

  function getLabel(tabId: string): string {
    return [...tabBtns].find((b) => b.dataset.tab === tabId)?.textContent?.trim() ?? '';
  }

  function isSlider(tabId: string): boolean {
    return (TABS[tabId]?.length ?? 0) > 1;
  }

  let swapToken = 0;

  async function fadeSwap(src: string, label: string) {
    const cur = layers.find((l) => l.classList.contains('is-active')) ?? layers[0]!;
    const next = layers.find((l) => l !== cur)!;
    if (cur.currentSrc.endsWith(src) || cur.src.endsWith(src)) return;

    const token = ++swapToken;
    next.src = src;
    next.alt = `TerraCore | ${label}`;
    try {
      await next.decode();
    } catch {
      /* decode can reject if src changes mid-flight; crossfade anyway */
    }
    if (token !== swapToken) return; // a newer swap superseded this one

    next.classList.add('is-active');
    cur.classList.remove('is-active');
    cur.setAttribute('aria-hidden', 'true');
    next.removeAttribute('aria-hidden');
  }

  function renderDots(tabId: string) {
    dotsEl.innerHTML = '';
    const images = TABS[tabId] ?? [];
    if (images.length <= 1) return;
    images.forEach((_, i) => {
      const dot = document.createElement('button');
      dot.className = 'showcase-dot' + (i === slideIdx ? ' active' : '');
      dot.setAttribute('aria-label', `Imagen ${i + 1}`);
      dot.addEventListener('click', () => goToSlide(i, true));
      dotsEl.appendChild(dot);
    });
  }

  function updateDots() {
    dotsEl.querySelectorAll('.showcase-dot').forEach((dot, i) => {
      dot.classList.toggle('active', i === slideIdx);
    });
  }

  function stopAutoplay() {
    if (timerId !== null) {
      clearInterval(timerId);
      timerId = null;
    }
  }

  function startAutoplay() {
    if (!isSlider(activeTab)) return;
    stopAutoplay();
    timerId = setInterval(() => goToSlide(slideIdx + 1), INTERVAL);
  }

  function goToSlide(index: number, resetTimer = false) {
    const images = TABS[activeTab] ?? [];
    slideIdx = ((index % images.length) + images.length) % images.length;
    fadeSwap(images[slideIdx]!, getLabel(activeTab));
    updateDots();
    if (resetTimer) {
      stopAutoplay();
      startAutoplay();
    }
  }

  function activateTab(tabId: string) {
    stopAutoplay();
    activeTab = tabId;
    slideIdx = 0;
    const images = TABS[tabId] ?? [];
    fadeSwap(images[0]!, getLabel(tabId));
    const slider = isSlider(tabId);
    renderDots(tabId);
    if (slider) startAutoplay();
  }

  tabBtns.forEach((btn) => {
    btn.addEventListener('click', () => {
      tabBtns.forEach((b) => {
        b.classList.remove('active');
        b.setAttribute('aria-selected', 'false');
      });
      btn.classList.add('active');
      btn.setAttribute('aria-selected', 'true');
      activateTab(btn.dataset.tab!);
    });
  });

  frame.addEventListener('mouseenter', stopAutoplay);
  frame.addEventListener('mouseleave', () => {
    if (isSlider(activeTab)) startAutoplay();
  });

  // Init
  renderDots('dashboard');
  startAutoplay();
</script>

<style>
  .showcase {
    background: var(--color-primary-active);
    color: #fff;
    padding: 120px 0;
    position: relative;
    overflow: hidden;
  }
  .showcase__bg {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(800px 600px at 90% 20%, rgba(217, 119, 6, 0.18), transparent 60%),
      radial-gradient(600px 400px at 0% 100%, rgba(60, 117, 86, 0.4), transparent 70%);
    pointer-events: none;
  }
  .showcase__heading {
    color: #fff;
    margin-top: 16px;
  }
  .showcase__heading .accent {
    color: var(--color-accent);
  }
  .showcase__lead {
    color: rgba(255, 255, 255, 0.72);
  }

  /* Tabs */
  .showcase-tabs {
    display: flex;
    gap: 6px;
    margin: 36px 0 28px;
    padding: 6px;
    background: rgba(255, 255, 255, 0.06);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 12px;
    width: fit-content;
    flex-wrap: wrap;
  }
  .showcase-tab {
    padding: 10px 16px;
    border-radius: 8px;
    font-size: 13px;
    font-weight: 500;
    color: rgba(255, 255, 255, 0.7);
    transition: all var(--dur-base) var(--ease-standard);
    cursor: pointer;
  }
  .showcase-tab:hover {
    color: #fff;
    background: rgba(255, 255, 255, 0.04);
  }
  .showcase-tab.active {
    background: var(--color-accent);
    color: #fff;
  }

  /* Frame */
  .showcase-frame {
    position: relative;
    background: transparent;
    aspect-ratio: 1200 / 750;
  }
  .showcase-frame img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    display: block;
    object-fit: contain;
    object-position: center;
    opacity: 0;
    transition: opacity 0.45s ease;
  }
  .showcase-frame img.is-active {
    opacity: 1;
  }
  @media (prefers-reduced-motion: reduce) {
    .showcase-frame img {
      transition: none;
    }
  }

  /* Dots */
  .showcase-dots {
    display: flex;
    justify-content: center;
    gap: 8px;
    margin-top: 14px;
    min-height: 12px;
  }
  :global(.showcase-dot) {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.3);
    border: none;
    cursor: pointer;
    transition:
      background var(--dur-base) var(--ease-standard),
      transform var(--dur-base) var(--ease-standard);
    padding: 0;
  }
  :global(.showcase-dot.active) {
    background: var(--color-accent);
    transform: scale(1.25);
  }
  :global(.showcase-dot:hover) {
    background: rgba(255, 255, 255, 0.6);
  }

  /* Callouts */
  .showcase-callouts {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
    margin-top: 40px;
  }
  .showcase-callout {
    border-top: 1px solid rgba(255, 255, 255, 0.16);
    padding-top: 16px;
  }
  .showcase-callout__num {
    font-family: var(--font-display);
    font-size: 12px;
    letter-spacing: 0.12em;
    color: var(--color-accent);
    font-weight: 600;
    font-variant-numeric: tabular-nums;
    margin-bottom: 8px;
  }
  .showcase-callout__title {
    font-family: var(--font-display);
    font-size: 17px;
    font-weight: 600;
    color: #fff;
    margin: 0 0 6px;
    letter-spacing: -0.01em;
  }
  .showcase-callout__desc {
    font-size: 13px;
    line-height: 20px;
    color: rgba(255, 255, 255, 0.7);
    margin: 0;
  }

  @media (max-width: 720px) {
    .showcase-callouts {
      grid-template-columns: 1fr;
    }
    .showcase {
      padding: 72px 0;
    }
    .showcase-tabs {
      width: 100%;
      justify-content: center;
    }
  }
</style>
