---
import Eyebrow from '@atoms/Eyebrow.astro';
import { Icon } from 'astro-icon/components';

const items = [
  {
    icon: 'lucide:shield',
    h: 'Cifrado en tránsito',
    p: 'TLS en todos los endpoints. Ninguna comunicación viaja sin cifrar.',
  },
  {
    icon: 'lucide:users',
    h: 'Roles y permisos',
    p: 'Cada usuario ve solo lo que necesita según su rol. Sin accesos de más, sin información expuesta.',
  },
  {
    icon: 'lucide:cloud',
    h: 'Tus datos, tuyos',
    p: 'Exporta a CSV cuando quieras. Si decides irte, te entregamos todo en 48 horas sin preguntas.',
  },
  {
    icon: 'lucide:eye-off',
    h: 'Sin minería de datos',
    p: 'Tu información no se usa para publicidad ni para entrenar modelos de IA. Punto.',
  },
  {
    icon: 'lucide:server',
    h: 'Operación continua garantizada',
    p: 'Infraestructura con alta disponibilidad y backups automáticos. Si algo falla, tus datos están seguros y la operación no se detiene.',
  },
];
---

<section class="security reveal">
  <div class="container">
    <div class="security-head">
      <div>
        <Eyebrow num="05" onDark>Privacidad y seguridad</Eyebrow>
        <h2 class="display lg security-heading">
          Tu finca es tuya.<br /><span class="accent">Tus datos también.</span>
        </h2>
      </div>
      <p class="security-lead">
        Tus datos no se comparten, no se venden y no se usan para entrenar IA. Si decides irte, te
        entregamos todo en 48 horas. Así de simple.
      </p>
    </div>

    <div class="security-grid">
      {
        items.map((it) => (
          <div class="security-item">
            <div class="security-item__icon">
              <Icon name={it.icon} width={20} height={20} />
            </div>
            <h3 class="security-item__title">{it.h}</h3>
            <p class="security-item__desc">{it.p}</p>
          </div>
        ))
      }
    </div>
  </div>
</section>

<style>
  .security {
    background: var(--color-primary-active);
    color: #fff;
    padding: 80px 0;
    position: relative;
    overflow: hidden;
  }
  .security::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(700px 500px at 50% 120%, rgba(217, 119, 6, 0.18), transparent 60%);
    pointer-events: none;
  }
  .container {
    position: relative;
  }

  .security-head {
    display: grid;
    grid-template-columns: 1fr;
    gap: 16px;
    align-items: start;
    margin-bottom: 56px;
  }
  .security-heading {
    color: #fff;
    margin-top: 16px;
  }
  .security-heading .accent {
    color: var(--color-accent);
  }
  .security-lead {
    color: rgba(255, 255, 255, 0.7);
    margin: 0;
    font-size: 15px;
    line-height: 24px;
  }

  @media (max-width: 880px) {
    .security-head {
      grid-template-columns: 1fr;
      gap: 16px;
    }
  }

  .security-grid {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: 32px;
  }
  @media (max-width: 1024px) {
    .security-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }
  @media (max-width: 880px) {
    .security-grid {
      grid-template-columns: repeat(2, 1fr);
    }
    /* Lone last card fills the row instead of leaving a gap */
    .security-item:last-child {
      grid-column: 1 / -1;
    }
  }
  @media (max-width: 540px) {
    .security-grid {
      grid-template-columns: 1fr;
    }
  }

  .security-item__icon {
    width: 40px;
    height: 40px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 10px;
    background: rgba(255, 255, 255, 0.06);
    border: 1px solid rgba(255, 255, 255, 0.12);
    color: var(--color-accent);
    margin-bottom: 16px;
  }
  .security-item__title {
    font-family: var(--font-display);
    font-size: 17px;
    font-weight: 700;
    margin: 0 0 6px;
    color: #fff;
    letter-spacing: -0.01em;
  }
  .security-item__desc {
    font-size: 13px;
    line-height: 20px;
    color: rgba(255, 255, 255, 0.7);
    margin: 0;
  }
</style>
