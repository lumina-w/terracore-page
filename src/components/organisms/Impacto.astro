---
import Eyebrow from '@atoms/Eyebrow.astro';
import { Icon } from 'astro-icon/components';
import { IMPACT_ROWS as rows } from '@utils/constants';
---

<section class="section-pad impacto reveal" id="impacto">
  <div class="container">
    <div class="section-head">
      <div>
        <Eyebrow num="·">Impacto</Eyebrow>
        <h2 class="display lg" style="margin-top:16px">
          Lo que cambia cuando operas con <span class="accent-text">información real</span>.
        </h2>
      </div>
      <p class="lead">El problema no es falta de trabajo. Es falta de visibilidad.</p>
    </div>

    <div class="ba">
      <div class="ba-head ba-head--before">Antes</div>
      <div class="ba-head ba-head--after">Después</div>
      {
        rows.map((r) => (
          <Fragment>
            <div class="ba-cell ba-cell--before">
              <Icon name="lucide:x" width={18} height={18} class="ba-ico ba-ico--before" />
              <span>{r.before}</span>
            </div>
            <div class="ba-cell ba-cell--after">
              <Icon name="lucide:check" width={18} height={18} class="ba-ico ba-ico--after" />
              <span>{r.after}</span>
            </div>
          </Fragment>
        ))
      }
    </div>

    <div class="impacto-stat">
      <div class="impacto-stat__val">−42%</div>
      <div class="impacto-stat__body">
        <div class="impacto-stat__label">
          menos tiempo en tareas administrativas · fincas piloto
        </div>
        <p class="impacto-stat__context">
          En las fincas piloto, los administradores redujeron el tiempo en tareas administrativas
          casi a la mitad. Ese tiempo volvió al campo.
        </p>
      </div>
    </div>
  </div>
</section>

<style>
  #impacto .section-head {
    grid-template-columns: 1fr;
    gap: 16px;
    align-items: start;
  }
  .ba {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 12px;
    margin-top: 40px;
  }
  .ba-head {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 15px;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    padding: 12px 18px;
    border-radius: 10px;
  }
  .ba-head--before {
    color: var(--color-text-secondary);
    background: var(--color-surface-sunken);
  }
  .ba-head--after {
    color: var(--color-accent-fg);
    background: var(--color-accent);
  }
  .ba-cell {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 16px 18px;
    border-radius: 10px;
    font-size: 15px;
    line-height: 1.35;
    border: 1px solid var(--color-border);
  }
  .ba-cell--before {
    background: var(--color-surface);
    color: var(--color-text-secondary);
  }
  .ba-cell--after {
    background: var(--color-surface);
    color: var(--color-text);
    font-weight: 600;
    border-color: var(--color-border-strong);
  }
  .ba-ico {
    flex: 0 0 auto;
  }
  .ba-ico--before {
    color: var(--color-text-muted);
  }
  .ba-ico--after {
    color: var(--color-accent);
  }

  .impacto-stat {
    display: flex;
    align-items: center;
    gap: 28px;
    margin-top: 40px;
    padding: 32px;
    border-radius: 16px;
    background: var(--color-text);
    color: var(--color-text-on-dark);
  }
  .impacto-stat__val {
    font-family: var(--font-display);
    font-size: clamp(48px, 8vw, 76px);
    font-weight: 700;
    font-variant-numeric: tabular-nums;
    letter-spacing: -0.02em;
    line-height: 1;
    color: var(--color-accent);
    flex: 0 0 auto;
  }
  .impacto-stat__label {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 17px;
    line-height: 1.3;
  }
  .impacto-stat__context {
    margin: 10px 0 0;
    font-size: 15px;
    line-height: 1.5;
    color: rgba(255, 255, 255, 0.78);
  }

  @media (max-width: 640px) {
    .ba {
      grid-template-columns: 1fr;
      gap: 8px;
    }
    .ba-head {
      display: none;
    }
    .impacto-stat {
      flex-direction: column;
      align-items: flex-start;
      gap: 16px;
      padding: 24px;
    }
  }
</style>
