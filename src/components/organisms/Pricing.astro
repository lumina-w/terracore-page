---
import Eyebrow from '@atoms/Eyebrow.astro';
import { Icon } from 'astro-icon/components';

const plans = [
  {
    name: 'Semilla',
    desc: 'Para fincas que quieren dejar de operar a ciegas.',
    priceMain: '$2.5M',
    priceSub: '/mes',
    priceIsLabel: false,
    priceNote: 'Acceso completo por 14 días',
    valueNote: 'Menos de lo que cuesta una compra de urgencia evitable al mes.',
    features: [
      'Deja de operar de memoria y con cuadernos',
      'Alertas antes de perder un animal o un insumo',
      '1 sede · 5 usuarios',
      'Gestión de Animales (CRUD completo + estado de salud)',
      'Salud Animal (vacunas + alertas próximas 30 días)',
      'Producción (lotes + eventos)',
      'Inventario (insumos + alertas stock)',
      'Dashboard (4 KPI principales)',
      'Autenticación (Admin + Operario)',
    ],
    cta: 'Comenzar trial gratis',
    ctaHref: 'https://app.terracoreapp.co/login',
    featured: false,
  },
  {
    name: 'Profesional',
    desc: 'Para operaciones que necesitan saber exactamente qué genera y qué cuesta cada área.',
    priceMain: '$5M',
    priceSub: '/mes',
    priceIsLabel: false,
    priceNote: null,
    features: [
      'Sabe exactamente qué área de tu finca es rentable',
      'Cero compras de urgencia con alertas anticipadas',
      '3 sedes · 15 usuarios',
      'Todo lo de Semilla +',
      'Gestión de Herramientas (mantenimiento)',
      'Costos automáticos por lote (rentabilidad)',
      'Proveedores y Compras',
      'Dashboard avanzado (comparativos, tendencias)',
      'Importación CSV en bulk',
      'WhatsApp + videollamada ≤4h + revisión mensual',
    ],
    featured: true,
    cta: 'Quiero saber más',
    ctaHref:
      'https://wa.me/573108283088?text=Hola%2C%20quiero%20saber%20m%C3%A1s%20sobre%20el%20plan%20Profesional%20de%20TerraCore',
  },
  {
    name: 'Enterprise',
    desc: 'Para grupos empresariales y cooperativas.',
    priceMain: 'Desde $10M',
    priceSub: '/mes',
    priceIsLabel: false,
    priceNote: '* Precio según operación · contáctanos',
    features: [
      'Visibilidad consolidada de toda tu operación multifinca',
      'Trazabilidad para certificaciones y acceso a mejores mercados',
      'Sedes y usuarios ilimitados',
      'Todo lo de Profesional +',
      'Vista consolidada multifinca',
      'Trazabilidad GlobalG.A.P.',
      'Logística y despachos',
      'API para integraciones',
      'Reportes gerenciales',
      'Soporte prioritario 24h · Implementación dedicada · Revisiones trimestrales',
    ],
    cta: 'Quiero saber más',
    ctaHref:
      'https://wa.me/573108283088?text=Hola%2C%20quiero%20saber%20m%C3%A1s%20sobre%20el%20plan%20Enterprise%20de%20TerraCore',
    featured: false,
  },
];
---

<section class="section-pad pricing reveal" id="precios">
  <div class="container">
    <div class="section-head">
      <div>
        <Eyebrow num="04">Precios</Eyebrow>
        <h2 class="display lg" style="margin-top:16px">
          Tres planes. <span class="accent-text">Sin sorpresas.</span>
        </h2>
      </div>
      <p class="lead">
        Pago mensual. Cancela cuando quieras con 30 días de aviso. El precio definitivo se confirma
        según tu operación.
      </p>
    </div>

    <p class="pricing-anchor">
      Una compra de urgencia evitada al mes paga el plan.
      <span class="accent-text">Todo lo demás es ganancia.</span>
    </p>

    <div class="plans-slider">
      <div class="slider-body">
        <button class="slider-arrow slider-arrow--prev" type="button" aria-label="Plan anterior">
          <Icon name="lucide:chevron-left" width={20} height={20} aria-hidden="true" />
        </button>
        <div class="plans-track">
          <div class="plans">
            {
              plans.map((p) => (
                <div class:list={['plan', p.featured && 'plan--featured']}>
                  {p.featured && <div class="plan-recommended">Recomendado</div>}
                  <div class="plan-header">
                    <div class="plan-name">{p.name}</div>
                    <h3 class="plan__title">{p.desc}</h3>
                  </div>
                  <div class="plan-offline-badge">
                    <Icon name="lucide:wifi-off" width={13} height={13} aria-hidden="true" />
                    Offline-first incluido
                  </div>
                  <div class="price-row">
                    {p.priceIsLabel ? (
                      <span class="price-label">{p.priceMain}</span>
                    ) : (
                      <>
                        <span class="price-amount">
                          {p.priceMain}
                          <sup>*</sup>
                        </span>
                        <span class="price-suffix">{p.priceSub}</span>
                      </>
                    )}
                  </div>
                  {p.priceNote && <p class="price-note">{p.priceNote}</p>}
                  {p.valueNote && <p class="price-value-note">{p.valueNote}</p>}
                  <hr class="plan-divider" />
                  <ul class="plan-features">
                    {p.features.map((f) => (
                      <li>
                        <Icon name="lucide:check" width={16} height={16} aria-hidden="true" />
                        {f}
                      </li>
                    ))}
                  </ul>
                  <a
                    href={p.ctaHref}
                    target="_blank"
                    rel="noopener noreferrer"
                    aria-label={`${p.cta}, plan ${p.name} (abre en una pestaña nueva)`}
                    class:list={['btn', p.featured ? 'btn-accent' : 'btn-ghost', 'plan-cta']}
                  >
                    {p.cta}
                    <Icon name="lucide:arrow-right" width={14} height={14} aria-hidden="true" />
                  </a>
                </div>
              ))
            }
          </div>
        </div>
        <button class="slider-arrow slider-arrow--next" type="button" aria-label="Plan siguiente">
          <Icon name="lucide:chevron-right" width={20} height={20} aria-hidden="true" />
        </button>
      </div>
      <button
        class="slider-pause"
        id="slider-pause"
        type="button"
        aria-pressed="false"
        aria-label="Pausar rotación automática de planes"
        hidden
      >
        <span class="slider-pause__glyph" aria-hidden="true"></span>
        <span class="slider-pause__label">Pausar</span>
      </button>
    </div>

    <p class="pricing-foot">
      Precios en pesos colombianos · IVA incluido para personas naturales, no incluido para personas
      jurídicas · Migración de datos incluida en planes Profesional y Enterprise
    </p>
  </div>
</section>

<script>
  // ── Infinite slider (clone-based) ──────────────────────────────────────────
  //
  // DOM after initSlider():
  //   [clone_last, card0, card1, card2, clone_first]
  //   idx:    0       1      2      3        4
  //
  // currentIndex stays in [1, TOTAL].
  // Landing on 0 → snap to TOTAL. Landing on TOTAL+1 → snap to 1.

  const TOTAL = 3;

  const plansEl = document.querySelector<HTMLElement>('.plans');
  const plansTrack = document.querySelector<HTMLElement>('.plans-track');
  const prevBtn = document.querySelector<HTMLButtonElement>('.slider-arrow--prev');
  const nextBtn = document.querySelector<HTMLButtonElement>('.slider-arrow--next');
  const pauseBtn = document.getElementById('slider-pause') as HTMLButtonElement | null;
  const sliderBody = document.querySelector<HTMLElement>('.slider-body');
  const origCards = Array.from(plansEl?.querySelectorAll<HTMLElement>(':scope > .plan') ?? []);

  const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  let currentIndex = 1;
  let sliderInited = false;
  let isTransitioning = false;
  let paused = prefersReduced;
  let timer: number | undefined;
  let resizeTimer: number | undefined;
  let safetyTimeout: number | undefined;

  const mqDesktop = window.matchMedia('(min-width: 1200px)');
  const mqMobile = window.matchMedia('(max-width: 639px)');

  function isSliderActive() {
    return !mqDesktop.matches && !mqMobile.matches;
  }

  function getCardW() {
    return plansTrack?.offsetWidth || 320;
  }

  function setPos(idx: number, animate: boolean) {
    if (!plansEl) return;
    if (!animate) plansEl.style.transition = 'none';
    plansEl.style.transform = `translateX(-${getCardW() * idx}px)`;
    if (!animate) {
      requestAnimationFrame(() => {
        requestAnimationFrame(() => {
          if (plansEl) plansEl.style.transition = '';
        });
      });
    }
  }

  function goToIndex(idx: number) {
    if (isTransitioning || !plansEl) return;
    currentIndex = idx;
    setPos(currentIndex, true);
    isTransitioning = true;
    if (safetyTimeout !== undefined) clearTimeout(safetyTimeout);
    safetyTimeout = window.setTimeout(() => {
      isTransitioning = false;
    }, 500);
  }

  function initSlider() {
    if (sliderInited || !plansEl || origCards.length !== TOTAL) return;

    const cloneLast = origCards[TOTAL - 1].cloneNode(true) as HTMLElement;
    cloneLast.dataset.sliderClone = 'true';
    cloneLast.setAttribute('aria-hidden', 'true');
    cloneLast.setAttribute('inert', '');
    plansEl.insertBefore(cloneLast, origCards[0]);

    const cloneFirst = origCards[0].cloneNode(true) as HTMLElement;
    cloneFirst.dataset.sliderClone = 'true';
    cloneFirst.setAttribute('aria-hidden', 'true');
    cloneFirst.setAttribute('inert', '');
    plansEl.appendChild(cloneFirst);

    sliderInited = true;
    currentIndex = 1;
    setPos(currentIndex, false);
  }

  function destroySlider() {
    if (!sliderInited || !plansEl) return;
    plansEl.querySelectorAll('[data-slider-clone]').forEach((c) => c.remove());
    plansEl.style.transform = '';
    plansEl.style.transition = '';
    sliderInited = false;
    isTransitioning = false;
  }

  function startTimer() {
    if (paused) return;
    if (timer !== undefined) clearInterval(timer);
    timer = window.setInterval(() => {
      if (isSliderActive()) goToIndex(currentIndex + 1);
    }, 5000);
  }

  function stopTimer() {
    if (timer !== undefined) {
      clearInterval(timer);
      timer = undefined;
    }
  }

  function setPaused(p: boolean) {
    paused = p;
    if (pauseBtn) {
      pauseBtn.setAttribute('aria-pressed', String(p));
      pauseBtn.setAttribute(
        'aria-label',
        p ? 'Reanudar rotación automática de planes' : 'Pausar rotación automática de planes',
      );
      pauseBtn.classList.toggle('is-paused', p);
      const label = pauseBtn.querySelector('.slider-pause__label');
      if (label) label.textContent = p ? 'Reanudar' : 'Pausar';
    }
    if (p) stopTimer();
    else if (isSliderActive()) startTimer();
  }

  plansEl?.addEventListener('transitionend', (e) => {
    if (e.target !== plansEl || (e as TransitionEvent).propertyName !== 'transform') return;
    isTransitioning = false;
    if (safetyTimeout !== undefined) clearTimeout(safetyTimeout);
    if (!plansEl || !sliderInited) return;

    if (currentIndex === 0) {
      currentIndex = TOTAL;
      setPos(currentIndex, false);
    } else if (currentIndex === TOTAL + 1) {
      currentIndex = 1;
      setPos(currentIndex, false);
    }
  });

  window.addEventListener('resize', () => {
    if (!isSliderActive() || !plansEl || !sliderInited) return;
    if (resizeTimer !== undefined) clearTimeout(resizeTimer);
    resizeTimer = window.setTimeout(() => setPos(currentIndex, false), 100);
  });

  prevBtn?.addEventListener('click', () => {
    if (!isSliderActive()) return;
    goToIndex(currentIndex - 1);
    startTimer();
  });

  nextBtn?.addEventListener('click', () => {
    if (!isSliderActive()) return;
    goToIndex(currentIndex + 1);
    startTimer();
  });

  function onBreakpointChange() {
    if (isSliderActive()) {
      initSlider();
      if (pauseBtn) pauseBtn.hidden = false;
      startTimer();
    } else {
      stopTimer();
      destroySlider();
      if (pauseBtn) pauseBtn.hidden = true;
    }
  }

  mqDesktop.addEventListener('change', onBreakpointChange);
  mqMobile.addEventListener('change', onBreakpointChange);

  pauseBtn?.addEventListener('click', () => setPaused(!paused));

  // Pause autoplay while interacting with the slider via keyboard
  sliderBody?.addEventListener('focusin', stopTimer);
  sliderBody?.addEventListener('focusout', () => {
    if (!paused && isSliderActive()) startTimer();
  });

  if (prefersReduced) setPaused(true);

  if (isSliderActive()) {
    initSlider();
    if (pauseBtn) pauseBtn.hidden = false;
    startTimer();
  }
</script>

<style>
  .accent-text {
    color: var(--color-accent);
  }

  .pricing {
    background: var(--color-surface-sunken);
  }

  /* Wider container just for pricing */
  .pricing :global(.container) {
    max-width: 1440px;
  }

  /* Single-column intro (override global two-column section-head) */
  .pricing .section-head {
    grid-template-columns: 1fr;
    gap: 16px;
    align-items: start;
  }

  .pricing-anchor {
    max-width: 900px;
    margin: 40px auto 48px;
    font-family: var(--font-display);
    font-size: clamp(24px, 4vw, 36px);
    font-weight: 700;
    line-height: 1.2;
    letter-spacing: -0.015em;
    color: var(--color-text);
    text-align: center;
  }

  /* ── Slider shell ── */

  .plans-slider {
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .slider-body {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 12px;
    width: 100%;
  }

  .plans-track {
    overflow: visible;
  }

  /* Mobile base: single column, stacked */
  .plans {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 16px;
    transition: transform 400ms ease;
  }

  /* Arrow buttons — hidden by default (mobile) */
  .slider-arrow {
    display: none;
    width: 40px;
    height: 40px;
    flex-shrink: 0;
    border-radius: 50%;
    border: 1px solid var(--color-border);
    background: var(--color-surface);
    color: var(--color-text);
    cursor: pointer;
    align-items: center;
    justify-content: center;
    transition:
      background 200ms,
      border-color 200ms;
  }

  .slider-arrow:hover {
    background: var(--color-surface-raised, var(--color-surface));
    border-color: var(--color-border-strong);
  }

  /* Autoplay pause toggle */
  .slider-pause {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    margin-top: 16px;
    padding: 7px 14px;
    border-radius: 999px;
    border: 1px solid var(--color-border);
    background: var(--color-surface);
    color: var(--color-text-secondary);
    font-size: 13px;
    font-weight: 600;
    cursor: pointer;
    transition:
      background 200ms,
      border-color 200ms;
  }
  .slider-pause[hidden] {
    display: none;
  }
  .slider-pause:hover {
    border-color: var(--color-border-strong);
    color: var(--color-text);
  }
  .slider-pause__glyph {
    width: 8px;
    height: 10px;
    border-left: 2px solid currentColor;
    border-right: 2px solid currentColor;
  }
  .slider-pause.is-paused .slider-pause__glyph {
    width: 0;
    height: 0;
    border: 0;
    border-left: 9px solid currentColor;
    border-top: 5px solid transparent;
    border-bottom: 5px solid transparent;
  }

  /* ── Plan card (base — must come before media queries so overrides work) ── */

  .plan {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 14px;
    padding: 32px;
    display: flex;
    flex-direction: column;
    gap: 28px;
    position: relative;
    min-width: 320px;
    max-width: 500px;
    width: 100%;
  }

  .plan[data-slider-clone] {
    pointer-events: none;
    user-select: none;
  }

  /* ── Slider: 640px–1199px ── */
  @media (min-width: 640px) and (max-width: 1199px) {
    .slider-body {
      gap: 16px;
    }

    .plans-track {
      /* flex: 1 1 0 lets track fill space between arrows, capped at 500px */
      flex: 1 1 0;
      min-width: 320px;
      max-width: 500px;
      overflow: hidden;
    }

    .plans {
      flex-direction: row;
      align-items: stretch;
      gap: 0;
      flex-wrap: nowrap;
      /* explicit width makes flex-basis: 100% on cards resolve to track width */
      width: 100%;
    }

    /* each card = exactly the track width; transform step = getCardW() */
    .plan {
      flex: 0 0 100%;
      width: 100%;
      min-width: unset;
      max-width: unset;
    }

    .slider-arrow {
      display: flex;
    }
  }

  /* ── Desktop: ≥1200px — three columns ── */
  @media (min-width: 1200px) {
    .plans-track {
      overflow: visible;
      flex: none;
      /* fill container up to 3×500px + 2×gap; slider-body centers it */
      width: 100%;
      max-width: calc(3 * 500px + 2 * 24px);
    }

    .plans {
      display: grid;
      grid-template-columns: repeat(3, minmax(320px, 1fr));
      align-items: stretch;
      gap: 24px;
    }

    .plan {
      width: auto;
      min-width: unset;
      flex: none;
    }
  }

  .plan--featured {
    background: var(--color-primary-active);
    border-color: var(--color-primary-active);
    color: #fff;
  }

  .plan-tag {
    position: absolute;
    top: -12px;
    right: 24px;
    background: var(--color-accent);
    color: #fff;
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    padding: 5px 10px;
    border-radius: 999px;
  }

  /* "Recomendado" badge overlapping the top-right corner of the featured card */
  .plan-recommended {
    position: absolute;
    top: -12px;
    right: -10px;
    z-index: 3;
    background: var(--color-accent);
    color: #fff;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    padding: 6px 14px;
    border-radius: 999px;
    box-shadow: 0 6px 16px -4px rgba(0, 0, 0, 0.4);
  }
  /* Slider view clips overflow, tuck the badge inside the card corner */
  @media (min-width: 640px) and (max-width: 1199px) {
    .plan-recommended {
      top: 12px;
      right: 12px;
    }
  }

  .plan-header {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .plan-name {
    font-size: 11px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-accent);
    font-weight: 700;
  }

  .plan__title {
    font-family: var(--font-display);
    font-size: 22px;
    font-weight: 700;
    margin: 0;
    letter-spacing: -0.015em;
    color: var(--color-text);
    line-height: 1.25;
  }

  .plan-offline-badge {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    align-self: flex-start;
    margin-top: 12px;
    padding: 4px 10px;
    border-radius: 999px;
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.01em;
    color: var(--color-success-fg);
    background: var(--color-success-bg);
    border: 1px solid var(--color-success-fg);
  }

  .plan--featured .plan-offline-badge {
    color: #fff;
    background: rgba(255, 255, 255, 0.12);
    border-color: rgba(255, 255, 255, 0.35);
  }

  .plan--featured .plan__title {
    color: #fff;
  }

  .price-row {
    display: flex;
    align-items: baseline;
    gap: 8px;
  }

  .price-amount {
    font-family: var(--font-display);
    font-size: 22px;
    font-weight: 700;
    font-variant-numeric: tabular-nums;
    letter-spacing: -0.02em;
    color: var(--color-text);
    line-height: 1;
  }

  .plan--featured .price-amount {
    color: #fff;
  }

  .price-suffix {
    font-size: 14px;
    color: var(--color-text-muted);
  }

  .price-note {
    font-size: 11px;
    color: var(--color-text-muted);
    margin: -20px 0 0;
  }

  .plan--featured .price-note {
    color: rgba(255, 255, 255, 0.55);
  }

  .price-value-note {
    font-size: 12px;
    line-height: 1.4;
    color: var(--color-accent);
    font-weight: 600;
    margin: 8px 0 0;
  }

  .plan--featured .price-value-note {
    color: var(--color-accent);
  }

  .plan--featured .price-suffix {
    color: rgba(255, 255, 255, 0.6);
  }

  .price-label {
    font-family: var(--font-display);
    font-size: 22px;
    font-weight: 700;
    color: var(--color-text);
    line-height: 1;
  }

  .plan--featured .price-label {
    color: #fff;
  }

  .plan-divider {
    border: 0;
    border-top: 1px solid var(--color-border);
    margin: 0;
  }

  .plan--featured .plan-divider {
    border-color: rgba(255, 255, 255, 0.12);
  }

  .plan-features {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 12px;
    flex: 1;
  }

  .plan-features li {
    display: flex;
    gap: 10px;
    font-size: 14px;
    line-height: 22px;
    color: var(--color-text);
    align-items: flex-start;
  }

  .plan--featured .plan-features li {
    color: rgba(255, 255, 255, 0.78);
  }

  .plan-features li :global(svg) {
    flex: 0 0 auto;
    color: var(--color-success);
    margin-top: 3px;
  }

  .plan--featured .plan-features li :global(svg) {
    color: var(--color-accent);
  }

  .plan-cta {
    width: 100%;
    justify-content: center;
  }

  .pricing-foot {
    margin-top: 32px;
    font-size: 13px;
    color: var(--color-text-muted);
    text-align: center;
  }
</style>
