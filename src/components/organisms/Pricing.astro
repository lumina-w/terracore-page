---
import Eyebrow from '@atoms/Eyebrow.astro';
import { Icon } from 'astro-icon/components';

const plans = [
  {
    name: 'Esencial',
    desc: 'Para fincas que arrancan a digitalizarse.',
    price: '—',
    suffix: 'A definir',
    features: ['Hasta 100 animales', '3 módulos a elección', '2 usuarios', 'Soporte por correo'],
    cta: 'Empezar',
    featured: false,
  },
  {
    name: 'Productor',
    desc: 'La elección de la mayoría de fincas medianas.',
    price: '—',
    suffix: 'A definir',
    features: [
      'Hasta 1.000 animales',
      '6 módulos completos',
      '8 usuarios + roles',
      'Soporte prioritario',
      'Integración con contabilidad',
      'Modo offline',
    ],
    cta: 'Solicita demo',
    featured: true,
  },
  {
    name: 'Empresa',
    desc: 'Para grupos agroindustriales con varias fincas.',
    price: '—',
    suffix: 'A definir',
    features: [
      'Animales ilimitados',
      'Multifinca consolidado',
      'Usuarios ilimitados',
      'SLA 99.9 %',
      'Onboarding dedicado',
      'API y exportación a medida',
    ],
    cta: 'Hablar con ventas',
    featured: false,
  },
] as const;
---

<section class="section-pad pricing" id="precios">
  <div class="container">
    <div class="section-head">
      <div>
        <Eyebrow num="04">Precios</Eyebrow>
        <h2 class="display lg" style="margin-top:16px">
          Tres planes. <span class="accent-text">Sin sorpresas.</span>
        </h2>
      </div>
      <p class="lead">
        Pago mensual o anual con descuento. Cancelas cuando quieras. Los precios definitivos se
        confirman con tu equipo según cantidad de animales y módulos activos.
      </p>
    </div>

    <div class="plans">
      {
        plans.map((p) => (
          <div class:list={['plan', p.featured && 'plan--featured']}>
            {p.featured && <div class="plan-tag">Más popular</div>}
            <div>
              <div class="plan-name">{p.name}</div>
              <h3 class="plan__title">{p.desc}</h3>
            </div>
            <div class="price-row">
              <span class="price-amount">{p.price}</span>
              <span class="price-suffix">{p.suffix}</span>
            </div>
            <hr class="plan-divider" />
            <ul class="plan-features">
              {p.features.map((f) => (
                <li>
                  <Icon name="lucide:check" width={16} height={16} />
                  {f}
                </li>
              ))}
            </ul>
            <a
              href="#demo"
              class:list={['btn', p.featured ? 'btn-accent' : 'btn-ghost', 'plan-cta']}
            >
              {p.cta}
              <Icon name="lucide:arrow-right" width={14} height={14} />
            </a>
          </div>
        ))
      }
    </div>

    <p class="pricing-foot">
      Precios en pesos colombianos · IVA no incluido · Migración desde Excel sin costo en todos los
      planes.
    </p>
  </div>
</section>

<style>
  .accent-text {
    color: var(--color-accent);
  }
  .pricing {
    background: var(--color-surface-sunken);
  }

  .plans {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 16px;
  }
  @media (max-width: 880px) {
    .plans {
      grid-template-columns: 1fr;
    }
  }

  .plan {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 14px;
    padding: 32px;
    display: flex;
    flex-direction: column;
    gap: 20px;
    position: relative;
  }
  .plan--featured {
    background: var(--color-primary-active);
    border-color: var(--color-primary-active);
    color: #fff;
  }

  .plan-tag {
    position: absolute;
    top: -12px;
    right: 24px;
    background: var(--color-accent);
    color: #fff;
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    padding: 5px 10px;
    border-radius: 999px;
  }

  .plan-name {
    font-size: 11px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-accent);
    font-weight: 700;
  }

  .plan__title {
    font-family: var(--font-display);
    font-size: 28px;
    font-weight: 700;
    margin: 6px 0 0;
    letter-spacing: -0.015em;
    color: var(--color-text);
  }
  .plan--featured .plan__title {
    color: #fff;
  }

  .price-row {
    display: flex;
    align-items: baseline;
    gap: 8px;
  }
  .price-amount {
    font-family: var(--font-display);
    font-size: 44px;
    font-weight: 700;
    font-variant-numeric: tabular-nums;
    letter-spacing: -0.02em;
    color: var(--color-text);
    line-height: 1;
  }
  .plan--featured .price-amount {
    color: #fff;
  }
  .price-suffix {
    font-size: 14px;
    color: var(--color-text-muted);
  }
  .plan--featured .price-suffix {
    color: rgba(255, 255, 255, 0.6);
  }

  .plan-divider {
    border: 0;
    border-top: 1px solid var(--color-border);
    margin: 0;
  }
  .plan--featured .plan-divider {
    border-color: rgba(255, 255, 255, 0.12);
  }

  .plan-features {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 10px;
    flex: 1;
  }
  .plan-features li {
    display: flex;
    gap: 10px;
    font-size: 14px;
    line-height: 22px;
    color: var(--color-text);
    align-items: flex-start;
  }
  .plan--featured .plan-features li {
    color: rgba(255, 255, 255, 0.78);
  }
  .plan-features li :global(svg) {
    flex: 0 0 auto;
    color: var(--color-success);
    margin-top: 3px;
  }
  .plan--featured .plan-features li :global(svg) {
    color: var(--color-accent);
  }

  .plan-cta {
    width: 100%;
    justify-content: center;
  }

  .pricing-foot {
    margin-top: 32px;
    font-size: 13px;
    color: var(--color-text-muted);
    text-align: center;
  }
</style>
