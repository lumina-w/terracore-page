---
import Eyebrow from '@atoms/Eyebrow.astro';
import { Icon } from 'astro-icon/components';

const plans = [
  {
    name: 'Semilla',
    desc: 'Fincas pequeñas que inician su digitalización.',
    priceMain: 'Desde $10M',
    priceSub: '/mes',
    priceIsLabel: false,
    features: [
      '1 sede · hasta 5 usuarios',
      'Módulos base incluidos',
      'Dashboard básico',
      'Trazabilidad básica',
      'Modo offline',
      '3 sesiones de capacitación remota',
      'Soporte WhatsApp en horario hábil (≤8h)',
    ],
    cta: 'Agendar demo',
    featured: false,
    waitlist: false,
  },
  {
    name: 'Profesional',
    desc: 'Operaciones medianas que necesitan visibilidad total.',
    priceMain: 'Solicitar precio',
    priceSub: '',
    priceIsLabel: true,
    features: [
      'Hasta 3 sedes · hasta 15 usuarios',
      'Todo de Semilla',
      'Costos de producción por lote',
      'Gestión de compras y proveedores',
      'Dashboard avanzado',
      'Migración de datos incluida',
      'Onboarding extendido',
      '2h consultoría/mes',
      'Soporte WhatsApp + videollamada (≤4h)',
      'Revisión mensual de uso',
    ],
    cta: 'Agendar demo',
    featured: true,
    waitlist: true,
  },
  {
    name: 'Enterprise',
    desc: 'Grupos empresariales y cooperativas.',
    priceMain: 'Solicitar precio',
    priceSub: '',
    priceIsLabel: true,
    features: [
      'Sedes ilimitadas · usuarios ilimitados',
      'Todo de Profesional',
      'Vista consolidada multifinca',
      'Trazabilidad completa',
      'Logística y despachos',
      'Dashboard personalizado',
      'Reportes a medida',
      'API (bajo alcance definido)',
      'Integraciones disponibles según alcance',
      'Migración avanzada incluida',
      'Acompañamiento 30 días',
      '6h consultoría/mes',
      'Soporte prioritario con SLA (≤2h)',
      'Revisión quincenal',
    ],
    cta: 'Agendar demo',
    featured: false,
    waitlist: true,
  },
];
---

<section class="section-pad pricing" id="precios">
  <div class="container">
    <div class="section-head">
      <div>
        <Eyebrow num="04">Precios</Eyebrow>
        <h2 class="display lg" style="margin-top:16px">
          Tres planes. <span class="accent-text">Sin sorpresas.</span>
        </h2>
      </div>
      <p class="lead">
        Pago mensual. Cancelas cuando quieras. El precio definitivo se confirma según tu operación.
      </p>
    </div>

    <div class="plans">
      {
        plans.map((p) => (
          <div class:list={['plan', p.featured && 'plan--featured']}>
            {p.featured && <div class="plan-tag">Más popular</div>}
            <div class="plan-header">
              <div class="plan-name">{p.name}</div>
              <h3 class="plan__title">{p.desc}</h3>
            </div>
            <div class="price-row">
              {p.priceIsLabel ? (
                <span class="price-label">{p.priceMain}</span>
              ) : (
                <>
                  <span class="price-amount">{p.priceMain}</span>
                  <span class="price-suffix">{p.priceSub}</span>
                </>
              )}
            </div>
            <hr class="plan-divider" />
            <ul class="plan-features">
              {p.features.map((f) => (
                <li>
                  <Icon name="lucide:check" width={16} height={16} />
                  {f}
                </li>
              ))}
            </ul>
            {p.waitlist ? (
              <div class="waitlist-block">
                <div class="coming-badge">Próximamente</div>
                <form class="waitlist-form" data-plan={p.name}>
                  <input
                    type="email"
                    name="email"
                    placeholder="tu@email.com"
                    required
                    class="waitlist-input"
                  />
                  <button
                    type="submit"
                    class:list={['btn', p.featured ? 'btn-accent' : 'btn-ghost', 'waitlist-btn']}
                  >
                    Notifícame
                  </button>
                </form>
                <p class="waitlist-confirm" hidden>Te avisamos cuando esté disponible</p>
              </div>
            ) : (
              <a
                href="#demo"
                class:list={['btn', p.featured ? 'btn-accent' : 'btn-ghost', 'plan-cta']}
              >
                {p.cta}
                <Icon name="lucide:arrow-right" width={14} height={14} />
              </a>
            )}
          </div>
        ))
      }
    </div>

    <p class="pricing-foot">
      Precios en pesos colombianos · IVA incluido para personas naturales, no incluido para personas
      jurídicas · Migración de datos incluida en planes Profesional y Enterprise
    </p>
  </div>
</section>

<script>
  document.querySelectorAll<HTMLFormElement>('.waitlist-form').forEach((form) => {
    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      const input = form.querySelector<HTMLInputElement>('input[name="email"]')!;
      const btn = form.querySelector<HTMLButtonElement>('button[type="submit"]')!;
      const confirmEl = form.nextElementSibling as HTMLElement;
      const email = input.value.trim();
      if (!email) return;

      btn.disabled = true;
      btn.textContent = 'Enviando…';

      try {
        const res = await fetch('/api/v1/waitlist/', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ email }),
        });

        if (res.ok) {
          form.hidden = true;
          confirmEl.hidden = false;
        } else {
          btn.disabled = false;
          btn.textContent = 'Notifícame';
          confirmEl.textContent = 'Algo salió mal. Intenta de nuevo.';
          confirmEl.hidden = false;
        }
      } catch {
        btn.disabled = false;
        btn.textContent = 'Notifícame';
        confirmEl.textContent = 'Algo salió mal. Intenta de nuevo.';
        confirmEl.hidden = false;
      }
    });
  });
</script>

<style>
  .accent-text {
    color: var(--color-accent);
  }
  .pricing {
    background: var(--color-surface-sunken);
  }

  .plans {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 16px;
  }
  @media (max-width: 880px) {
    .plans {
      grid-template-columns: 1fr;
    }
  }

  .plan {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 14px;
    padding: 32px;
    display: flex;
    flex-direction: column;
    gap: 28px;
    position: relative;
  }
  .plan--featured {
    background: var(--color-primary-active);
    border-color: var(--color-primary-active);
    color: #fff;
  }

  .plan-tag {
    position: absolute;
    top: -12px;
    right: 24px;
    background: var(--color-accent);
    color: #fff;
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    padding: 5px 10px;
    border-radius: 999px;
  }

  .plan-header {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .plan-name {
    font-size: 11px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-accent);
    font-weight: 700;
  }

  .plan__title {
    font-family: var(--font-display);
    font-size: 22px;
    font-weight: 700;
    margin: 0;
    letter-spacing: -0.015em;
    color: var(--color-text);
    line-height: 1.25;
  }
  .plan--featured .plan__title {
    color: #fff;
  }

  .price-row {
    display: flex;
    align-items: baseline;
    gap: 8px;
  }
  .price-amount {
    font-family: var(--font-display);
    font-size: 22px;
    font-weight: 700;
    font-variant-numeric: tabular-nums;
    letter-spacing: -0.02em;
    color: var(--color-text);
    line-height: 1;
  }
  .plan--featured .price-amount {
    color: #fff;
  }
  .price-suffix {
    font-size: 14px;
    color: var(--color-text-muted);
  }
  .plan--featured .price-suffix {
    color: rgba(255, 255, 255, 0.6);
  }
  .price-label {
    font-family: var(--font-display);
    font-size: 22px;
    font-weight: 700;
    color: var(--color-text);
    line-height: 1;
  }
  .plan--featured .price-label {
    color: #fff;
  }

  .plan-divider {
    border: 0;
    border-top: 1px solid var(--color-border);
    margin: 0;
  }
  .plan--featured .plan-divider {
    border-color: rgba(255, 255, 255, 0.12);
  }

  .plan-features {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 12px;
    flex: 1;
  }
  .plan-features li {
    display: flex;
    gap: 10px;
    font-size: 14px;
    line-height: 22px;
    color: var(--color-text);
    align-items: flex-start;
  }
  .plan--featured .plan-features li {
    color: rgba(255, 255, 255, 0.78);
  }
  .plan-features li :global(svg) {
    flex: 0 0 auto;
    color: var(--color-success);
    margin-top: 3px;
  }
  .plan--featured .plan-features li :global(svg) {
    color: var(--color-accent);
  }

  .plan-cta {
    width: 100%;
    justify-content: center;
  }

  /* Waitlist block */
  .waitlist-block {
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .coming-badge {
    display: inline-flex;
    align-self: flex-start;
    background: var(--color-accent);
    color: #fff;
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    padding: 5px 12px;
    border-radius: 999px;
  }

  .waitlist-form {
    display: flex;
    gap: 8px;
  }

  .waitlist-input {
    flex: 1;
    min-width: 0;
    padding: 10px 14px;
    border-radius: 8px;
    border: 1px solid var(--color-border);
    background: var(--color-surface);
    color: var(--color-text);
    font-size: 14px;
    outline: none;
    transition: border-color 0.15s;
  }
  .waitlist-input:focus {
    border-color: var(--color-accent);
  }
  .plan--featured .waitlist-input {
    background: rgba(255, 255, 255, 0.1);
    border-color: rgba(255, 255, 255, 0.2);
    color: #fff;
  }
  .plan--featured .waitlist-input::placeholder {
    color: rgba(255, 255, 255, 0.45);
  }
  .plan--featured .waitlist-input:focus {
    border-color: var(--color-accent);
  }

  .waitlist-btn {
    flex-shrink: 0;
    white-space: nowrap;
  }

  .waitlist-confirm {
    font-size: 13px;
    color: var(--color-success);
    margin: 0;
  }
  .plan--featured .waitlist-confirm {
    color: var(--color-accent);
  }

  .pricing-foot {
    margin-top: 32px;
    font-size: 13px;
    color: var(--color-text-muted);
    text-align: center;
  }
</style>
