---
import Brand from '@molecules/Brand.astro';
import { Icon } from 'astro-icon/components';

const ctaUrl = import.meta.env.MAIN_CTA_URL ?? '/#demo';
---

<header class="nav">
  <div class="nav-inner container">
    <!-- Logo -->
    <a href="/#top" aria-label="TerraCore inicio">
      <Brand size={40} />
    </a>

    <!-- Desktop links -->
    <nav class="nav-links" aria-label="Navegación principal">
      <a href="/#modulos">Módulos</a>
      <a href="/#producto">Producto</a>
      <a href="/#beneficios">Beneficios</a>
      <a href="/#precios">Precios</a>
      <a href="/#preguntas">Preguntas</a>
    </nav>

    <!-- Desktop CTA + mobile hamburger -->
    <div class="nav-cta">
      <a href="https://terracoreapp.co/login" target="_blank" class="btn nav-login">
        Iniciar sesión
        <Icon name="lucide:log-in" width={16} height={16} />
      </a>
      <a
        href={ctaUrl}
        rel="noopener noreferrer"
        class="btn btn-primary nav-demo"
        onclick="window.trackEvent?.('click_cta_header')"
      >
        Solicita demo
        <Icon name="lucide:arrow-right" width={14} height={14} />
      </a>
      <button
        class="nav-toggle"
        aria-label="Abrir menú"
        aria-expanded="false"
        aria-controls="mobile-drawer"
      >
        <Icon name="lucide:menu" width={24} height={24} class="icon-menu" />
        <Icon name="lucide:x" width={24} height={24} class="icon-close" />
      </button>
    </div>
  </div>
</header>

<!-- Mobile drawer (renders outside nav-inner but still inside header context) -->
<div class="mobile-drawer" id="mobile-drawer" data-open="false" aria-hidden="true">
  <ul class="mobile-links">
    <li><a href="/#modulos">Módulos</a></li>
    <li><a href="/#producto">Producto</a></li>
    <li><a href="/#beneficios">Beneficios</a></li>
    <li><a href="/#precios">Precios</a></li>
    <li><a href="/#preguntas">Preguntas</a></li>
  </ul>
  <div class="mobile-divider" role="separator"></div>
  <a href="https://terracoreapp.co/login" target="_blank" class="mobile-login">
    Iniciar sesión
    <Icon name="lucide:log-in" width={16} height={16} />
  </a>
</div>

<script>
  const toggle = document.querySelector<HTMLButtonElement>('.nav-toggle')!;
  const drawer = document.querySelector<HTMLElement>('.mobile-drawer')!;
  const iconMenu = toggle.querySelector<SVGElement>('.icon-menu')!;
  const iconClose = toggle.querySelector<SVGElement>('.icon-close')!;

  function setOpen(open: boolean) {
    drawer.dataset.open = String(open);
    drawer.setAttribute('aria-hidden', String(!open));
    toggle.setAttribute('aria-expanded', String(open));
    iconMenu.style.display = open ? 'none' : '';
    iconClose.style.display = open ? '' : 'none';
  }

  // init: hide close icon
  iconClose.style.display = 'none';

  toggle.addEventListener('click', () => {
    setOpen(drawer.dataset.open !== 'true');
  });

  // close on link click
  drawer.querySelectorAll('a').forEach((link) => {
    link.addEventListener('click', () => setOpen(false));
  });

  // close on outside click
  document.addEventListener('click', (e) => {
    const target = e.target as Node;
    if (drawer.dataset.open === 'true' && !drawer.contains(target) && !toggle.contains(target)) {
      setOpen(false);
    }
  });
</script>

<style>
  /* ── Desktop nav ───────────────────────────────────────────── */
  .nav {
    position: sticky;
    top: 0;
    z-index: 50;
    background: #ffffff;
    border-bottom: 1px solid var(--color-border);
  }
  .nav-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 68px;
  }

  .nav-links {
    display: flex;
    gap: 28px;
    font-size: 14px;
    color: var(--color-text-secondary);
    font-weight: 500;
  }
  .nav-links a {
    transition:
      transform 180ms var(--ease-standard),
      color 180ms var(--ease-standard);
  }
  .nav-links a:hover {
    transform: scale(1.05);
    color: var(--color-text);
  }

  .nav-cta {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .nav-login {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    color: var(--color-accent);
    font-size: 14px;
    font-weight: 600;
    transition: color var(--dur-base) var(--ease-standard);
  }
  .nav-login:hover {
    color: var(--color-text);
  }

  .nav-demo {
    padding: 10px 16px !important;
    font-size: 14px !important;
  }

  /* Hamburger — desktop hidden */
  .nav-toggle {
    display: none;
    padding: 8px;
    border-radius: 8px;
    color: var(--color-text);
    background: transparent;
    border: 0;
    cursor: pointer;
    align-items: center;
    justify-content: center;
    transition: background var(--dur-base) var(--ease-standard);
  }
  .nav-toggle:hover {
    background: var(--color-surface-sunken);
  }

  /* ── Mobile breakpoint ─────────────────────────────────────── */
  @media (max-width: 1000px) {
    .nav-links {
      display: none;
    }
    .nav-login {
      display: none;
    } /* hidden in bar; appears in drawer */
    .nav-toggle {
      display: flex;
    }
    .nav-demo {
      padding: 8px 14px !important;
      font-size: 13px !important;
    }
  }

  /* ── Mobile drawer ─────────────────────────────────────────── */
  .mobile-drawer {
    position: fixed;
    top: 68px; /* matches nav height */
    left: 0;
    right: 0;
    background: #ffffff;
    border-bottom: 1px solid var(--color-border);
    padding: 20px 20px 28px;
    transform: translateY(-8px);
    opacity: 0;
    pointer-events: none;
    transition:
      transform 240ms var(--ease-standard),
      opacity 240ms var(--ease-standard);
    z-index: 49;
    box-shadow: 0 8px 24px rgba(13, 42, 31, 0.08);
  }
  .mobile-drawer[data-open='true'] {
    transform: translateY(0);
    opacity: 1;
    pointer-events: auto;
  }

  /* Hide on desktop */
  @media (min-width: 1001px) {
    .mobile-drawer {
      display: none !important;
    }
  }

  .mobile-links {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 2px;
  }
  .mobile-links a {
    display: block;
    padding: 13px 12px;
    font-size: 16px;
    font-weight: 500;
    color: var(--color-text);
    border-radius: 8px;
    transition: background var(--dur-base) var(--ease-standard);
  }
  .mobile-links a:hover,
  .mobile-links a:active {
    background: var(--color-surface-sunken);
  }

  .mobile-divider {
    height: 1px;
    background: var(--color-border);
    margin: 14px 0;
  }

  .mobile-login {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 10px 12px;
    font-size: 15px;
    font-weight: 600;
    color: var(--color-accent);
    border-radius: 8px;
    transition:
      color var(--dur-base) var(--ease-standard),
      background var(--dur-base) var(--ease-standard);
  }
  .mobile-login:hover {
    color: var(--color-text);
    background: var(--color-surface-sunken);
  }
</style>
