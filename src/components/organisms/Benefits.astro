---
import Eyebrow from '@atoms/Eyebrow.astro';
import { Icon } from 'astro-icon/components';

const items = [
  {
    icon: 'lucide:wifi',
    h: 'Funciona offline en la finca',
    p: 'Registra en el corral aunque no haya señal. Se sincroniza solo cuando vuelve la red.',
  },
  {
    icon: 'lucide:clock',
    h: 'En marcha en tu primera semana',
    p: 'Sin consultores, sin meses de implementación. En tu primera semana ya tienes datos reales.',
  },
  {
    icon: 'lucide:users',
    h: 'Pensado para varios roles',
    p: 'El dueño ve la rentabilidad. El administrador gestiona. El operario registra. Todos sobre la misma información.',
  },
  {
    icon: 'lucide:bar-chart-2',
    h: 'Decisiones con datos reales',
    p: 'Producción por mes, costo por lote, consumo de concentrado por animal. Lo que antes era suposición, ahora es un número.',
  },
  {
    icon: 'lucide:alert-circle',
    h: 'Nada se te pasa',
    p: 'Vacunas que vencen, stock bajo, animales en tratamiento. La alerta llega antes de que sea un problema.',
  },
  {
    icon: 'lucide:leaf',
    h: 'En español, para el campo',
    p: 'Sin jerga técnica. Sin términos en inglés. Hablamos de lotes, dosis, kilos y unidades, como en tu finca.',
  },
  {
    icon: 'lucide:handshake',
    h: 'Construido con productores colombianos',
    p: 'TerraCore nació de entrevistas y trabajo directo con productores de Urabá. No es un ERP genérico adaptado al campo: es una herramienta diseñada desde las necesidades reales de la finca.',
  },
];
---

<section class="section-pad benefits reveal" id="beneficios">
  <div class="container">
    <div class="section-head">
      <div>
        <Eyebrow num="03">Por qué TerraCore</Eyebrow>
        <h2 class="display lg" style="margin-top:16px">
          Construido desde el campo.<br />Para que pierdas <span style="color:var(--color-accent)"
            >menos</span
          > y controles más.
        </h2>
      </div>
      <p class="lead">
        Lo que probaste antes era un ERP disfrazado, o un Excel con login. TerraCore se construyó
        desde el campo, con productores de Urabá, no desde una oficina.
      </p>
    </div>

    <div class="benefits-grid">
      {
        items.map((it) => (
          <div class="benefit">
            <div class="benefit__icon">
              <Icon name={it.icon} width={26} height={26} />
            </div>
            <div>
              <h4 class="benefit__title">{it.h}</h4>
              <p class="benefit__desc">{it.p}</p>
            </div>
          </div>
        ))
      }
    </div>

    <!-- Photo + stat split -->
    <div class="split">
      <div>
      <div class="photo-card">
        <img
          src="/images/terracore.webp"
          alt="TerraCore en la finca"
          class="photo-img"
          loading="lazy"
          decoding="async"
        />
      </div>
    </div>

    <div>
      <Eyebrow num="·">Resultado</Eyebrow>
      <h3 class="display md" style="margin:16px 0">
        Menos planilla. <span style="color:var(--color-accent)">Más finca.</span>
      </h3>
      <p class="lead" style="margin-bottom:24px">
        El tiempo que se va en cuadernos, recibos y llamadas puede volver al campo. TerraCore
        centraliza todo en un solo lugar para que tú y tu equipo operen con información real, no con
        memoria.
      </p>
      <ul class="check-list">
        <li>
          <Icon name="lucide:check" width={18} height={18} class="check-list__icon" />
          Exporta a CSV cuando lo necesites, para tu contador, tu veterinario o tus registros internos.
        </li>
        <li>
          <Icon name="lucide:check" width={18} height={18} class="check-list__icon" />
          Importa tu inventario desde Excel sin perder ningún dato.
        </li>
        <li>
          <Icon name="lucide:check" width={18} height={18} class="check-list__icon" />
          Soporte humano en español, por WhatsApp en horario hábil.
        </li>
      </ul>
    </div>
    </div>
  </div>
</section>

<style>
  .benefits {
    background: var(--color-bg);
  }

  .benefits-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 40px 48px;
  }
  /* 7th benefit spans the full row, centered */
  .benefit:nth-child(7) {
    grid-column: 1 / -1;
    justify-content: center;
    max-width: 760px;
    margin: 0 auto;
  }
  @media (max-width: 1024px) {
    .benefits-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 32px 48px;
    }
    .benefit:nth-child(7) {
      grid-column: 1 / -1;
    }
  }
  @media (max-width: 880px) {
    .benefits-grid {
      grid-template-columns: 1fr;
      gap: 32px;
    }
    .benefit:nth-child(7) {
      grid-column: auto;
      max-width: none;
      margin: 0;
      justify-content: flex-start;
    }
  }

  .benefit {
    display: flex;
    gap: 20px;
    padding: 8px 0;
  }
  .benefit__icon {
    flex: 0 0 auto;
    width: 48px;
    height: 48px;
    border-radius: 10px;
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-accent);
  }
  .benefit__title {
    font-family: var(--font-display);
    font-size: 19px;
    font-weight: 700;
    margin: 0 0 6px;
    letter-spacing: -0.01em;
    color: var(--color-text);
  }
  .benefit__desc {
    font-size: 14px;
    line-height: 22px;
    color: var(--color-text-secondary);
    margin: 0;
  }

  /* Split */
  .split {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 48px;
    align-items: center;
    margin-top: 96px;
  }
  @media (max-width: 880px) {
    .split {
      grid-template-columns: 1fr;
      gap: 32px;
    }
  }

  /* Photo card */
  .photo-card {
    border-radius: 14px;
    overflow: hidden;
    background: var(--color-primary);
    position: relative;
    aspect-ratio: 4 / 5;
    border: 1px solid var(--color-border);
  }
  .photo-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  /* Check list */
  .check-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    gap: 12px;
  }
  .check-list li {
    display: flex;
    gap: 10px;
    font-size: 15px;
    align-items: flex-start;
  }
  :global(.check-list__icon) {
    color: var(--color-accent);
    margin-top: 3px;
    flex: 0 0 auto;
  }
</style>
