---
import { Image } from 'astro:assets';
import Eyebrow from '@atoms/Eyebrow.astro';
import { Icon } from 'astro-icon/components';
import { BENEFITS as items } from '@utils/constants';
import terracorePhoto from '../../assets/images/terracore.webp';
---

<section class="section-pad benefits reveal" id="beneficios">
  <div class="container">
    <div class="section-head">
      <div>
        <Eyebrow num="03">Por qué TerraCore</Eyebrow>
        <h2 class="display lg" style="margin-top:16px">
          Construido desde el campo.<br />Para que pierdas <span
            style="color:var(--color-text-link)">menos</span
          > y controles más.
        </h2>
      </div>
      <p class="lead">
        La realidad de la mayoría de fincas medianas sigue siendo Excel, cuadernos y WhatsApp.
        TerraCore se construyó desde el campo, con productores de Urabá, no desde una oficina.
      </p>
    </div>

    <div class="benefits-grid">
      {
        items.map((it) => (
          <div class="benefit">
            <div class="benefit__icon">
              <Icon name={it.icon} width={26} height={26} />
            </div>
            <div>
              <h3 class="benefit__title">{it.title}</h3>
              <p class="benefit__desc">{it.desc}</p>
            </div>
          </div>
        ))
      }
    </div>

    <!-- Photo + stat split -->
    <div class="split">
      <div>
        <div class="photo-card">
          <Image
            src={terracorePhoto}
            alt="TerraCore en la finca"
            class="photo-img"
            widths={[400, 600, 821]}
            sizes="(min-width: 880px) 500px, 100vw"
            loading="lazy"
            decoding="async"
          />
        </div>
      </div>

      <div>
        <Eyebrow num="·">Resultado</Eyebrow>
        <h3 class="display md" style="margin:16px 0">
          Menos planilla. <span style="color:var(--color-text-link)">Más finca.</span>
        </h3>
        <p class="lead" style="margin-bottom:24px">
          El tiempo que se va en cuadernos, recibos y llamadas puede volver al campo. TerraCore
          centraliza todo en un solo lugar para que tú y tu equipo operen con información real, no
          con memoria.
        </p>
        <ul class="check-list">
          <li>
            <Icon name="lucide:check" width={18} height={18} class="check-list__icon" />
            Exporta a CSV cuando lo necesites, para tu contador, tu veterinario o tus registros internos
            (planes Profesional y Enterprise).
          </li>
          <li>
            <Icon name="lucide:check" width={18} height={18} class="check-list__icon" />
            Importa tu inventario desde Excel sin perder ningún dato.
          </li>
          <li>
            <Icon name="lucide:check" width={18} height={18} class="check-list__icon" />
            Soporte humano en español, por WhatsApp en horario hábil.
          </li>
        </ul>
      </div>
    </div>
  </div>
</section>

<style>
  .benefits {
    background: var(--color-bg);
  }

  .benefits .section-head {
    grid-template-columns: 1fr;
    gap: 16px;
    align-items: start;
  }

  .benefits-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 40px 48px;
  }
  /* 7th benefit spans the full row, centered */
  .benefit:nth-child(7) {
    grid-column: 1 / -1;
    justify-content: center;
    max-width: 760px;
    margin: 0 auto;
  }
  @media (max-width: 1024px) {
    .benefits-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 32px 48px;
    }
    .benefit:nth-child(7) {
      grid-column: 1 / -1;
    }
  }
  @media (max-width: 880px) {
    .benefits-grid {
      grid-template-columns: 1fr;
      gap: 32px;
    }
    .benefit:nth-child(7) {
      grid-column: auto;
      max-width: none;
      margin: 0;
      justify-content: flex-start;
    }
  }

  .benefit {
    display: flex;
    gap: 20px;
    padding: 8px 0;
  }
  .benefit__icon {
    flex: 0 0 auto;
    width: 48px;
    height: 48px;
    border-radius: 10px;
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-accent);
  }
  .benefit__title {
    font-family: var(--font-display);
    font-size: 19px;
    font-weight: 700;
    margin: 0 0 6px;
    letter-spacing: -0.01em;
    color: var(--color-text);
  }
  .benefit__desc {
    font-size: 14px;
    line-height: 22px;
    color: var(--color-text-secondary);
    margin: 0;
  }

  /* Split */
  .split {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 48px;
    align-items: center;
    margin-top: 96px;
  }
  @media (max-width: 880px) {
    .split {
      grid-template-columns: 1fr;
      gap: 32px;
    }
  }

  /* Photo card */
  .photo-card {
    border-radius: 14px;
    overflow: hidden;
    background: var(--color-primary);
    position: relative;
    aspect-ratio: 4 / 5;
    border: 1px solid var(--color-border);
  }
  .photo-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  /* Check list */
  .check-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    gap: 12px;
  }
  .check-list li {
    display: flex;
    gap: 10px;
    font-size: 15px;
    align-items: flex-start;
  }
  :global(.check-list__icon) {
    color: var(--color-accent);
    margin-top: 3px;
    flex: 0 0 auto;
  }
</style>
