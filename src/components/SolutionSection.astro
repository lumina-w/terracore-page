---
import Card from './Card.astro'
import { FEATURES } from '@utils/constants'

const ctaUrl = import.meta.env.MAIN_CTA_URL ?? '#'
---

<section class="bg-background py-16 sm:py-24">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-12">
      <h2 class="text-3xl sm:text-4xl font-bold text-primary mb-4">
        Cómo TerraCore funciona
      </h2>
      <p class="text-lg text-muted-foreground max-w-2xl mx-auto">
        Tres pilares que transforman cómo gestionas tu operación agroindustrial.
      </p>
    </div>

    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
      {FEATURES.map((f) => (
        <Card
          title={f.title}
          description={f.description}
          icon={f.icon}
          cta={{ text: 'Ver demo', href: ctaUrl }}
        />
      ))}
    </div>
  </div>
</section>
