---
import Card from './Card.astro'

const features = [
  {
    icon: 'layout-dashboard',
    title: 'Dashboard centralizado',
    description:
      'Toda tu operación en una pantalla: inventario, personal, lotes y finanzas. Sin abrir diez hojas de cálculo.',
    cta: { text: 'Ver demo', href: import.meta.env.MAIN_CTA_URL ?? '#' },
  },
  {
    icon: 'bell-ring',
    title: 'Alertas en tiempo real',
    description:
      'Recibe notificaciones antes de que los problemas escalen. Actúa sobre datos, no sobre rumores.',
    cta: { text: 'Ver demo', href: import.meta.env.MAIN_CTA_URL ?? '#' },
  },
  {
    icon: 'shield-check',
    title: 'Control total de operación',
    description:
      'Toma decisiones basadas en rentabilidad real. Por lote, por mes, por cultivo. Sin adivinar.',
    cta: { text: 'Ver demo', href: import.meta.env.MAIN_CTA_URL ?? '#' },
  },
] as const
---

<section class="bg-background py-16 sm:py-24">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-12">
      <h2 class="text-3xl sm:text-4xl font-bold text-primary mb-4">
        Cómo TerraCore funciona
      </h2>
      <p class="text-lg text-muted-foreground max-w-2xl mx-auto">
        Tres pilares que transforman cómo gestionas tu operación agroindustrial.
      </p>
    </div>

    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
      {features.map((f) => (
        <Card
          title={f.title}
          description={f.description}
          icon={f.icon}
          cta={f.cta}
        />
      ))}
    </div>
  </div>
</section>
