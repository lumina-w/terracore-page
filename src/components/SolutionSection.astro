---
import Card from './Card.astro';
import { FEATURES } from '@utils/constants';

const ctaUrl = import.meta.env.MAIN_CTA_URL ?? 'https://calendly.com/wavival/30min';
---

<section class="bg-background py-16 sm:py-24">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="mb-12 text-center">
      <h2 class="mb-4 text-3xl font-bold text-primary sm:text-4xl">Cómo TerraCore funciona</h2>
      <p class="text-muted-foreground mx-auto max-w-2xl text-lg">
        Tres pilares que transforman cómo gestionas tu operación agroindustrial.
      </p>
    </div>

    <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {
        FEATURES.map((f) => (
          <Card
            title={f.title}
            description={f.description}
            icon={f.icon}
            cta={{ text: 'Ver demo', href: ctaUrl }}
          />
        ))
      }
    </div>
  </div>
</section>
