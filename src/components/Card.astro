---
import { Icon } from 'astro-icon/components'
import Button from './Button.astro'
import { cn } from '@utils/cn'

interface Props {
  title: string
  description: string
  icon?: string
  cta?: { text: string; href: string }
  class?: string
}

const { title, description, icon, cta, class: className } = Astro.props
---

<div
  class={cn(
    'bg-card border border-border rounded-lg shadow-sm p-6 flex flex-col gap-4',
    'hover:shadow-md transition-shadow duration-base ease-standard',
    className,
  )}
>
  {icon && (
    <div class="w-10 h-10 flex items-center justify-center rounded-md bg-primary/10 text-primary shrink-0">
      <Icon name={`lucide:${icon}`} class="w-5 h-5" />
    </div>
  )}

  <div class="flex flex-col gap-1.5">
    <h3 class="text-base font-semibold text-foreground">{title}</h3>
    <p class="text-sm text-muted-foreground leading-relaxed">{description}</p>
  </div>

  {cta && (
    <div class="mt-auto pt-2">
      <Button href={cta.href} variant="outline" size="sm">{cta.text}</Button>
    </div>
  )}
</div>
