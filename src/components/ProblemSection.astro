---
import { Icon } from 'astro-icon/components'
import { PROBLEMS } from '@utils/constants'
---

<section id="problema" class="bg-primary py-16 sm:py-24">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <h2 class="text-3xl sm:text-4xl font-bold text-white text-center mb-12">
      El problema que enfrenta tu operación hoy
    </h2>

    <div class="grid sm:grid-cols-2 gap-5">
      {PROBLEMS.map((item) => (
        <div
          class="flex items-start gap-4 p-6 rounded-lg"
          style="background: rgba(255,255,255,0.06)"
        >
          <div
            class="w-12 h-12 flex items-center justify-center rounded-lg shrink-0"
            style="background: rgba(255,255,255,0.12)"
          >
            <Icon name={`lucide:${item.icon}`} class="w-6 h-6 text-white" />
          </div>
          <div>
            <h3 class="font-semibold text-white mb-1">{item.title}</h3>
            <p class="text-sm text-white/70 leading-relaxed">{item.desc}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
