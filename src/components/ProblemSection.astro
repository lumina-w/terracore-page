---
import { Icon } from 'astro-icon/components'

const problems = [
  {
    icon: 'file-spreadsheet',
    title: 'Datos dispersos',
    desc: 'Información en Excel, WhatsApp y cuadernos. Sin una sola fuente de verdad.',
  },
  {
    icon: 'eye-off',
    title: 'Sin visibilidad en tiempo real',
    desc: 'No sabes el estado de salud animal ni de inventario hasta que ya es tarde.',
  },
  {
    icon: 'trending-down',
    title: 'Decisiones a ciegas',
    desc: 'Sin datos de rentabilidad por lote, cultivo o mes, no puedes optimizar.',
  },
  {
    icon: 'alert-triangle',
    title: 'Personal apagando incendios',
    desc: 'Tu equipo gestiona crisis en lugar de enfocarse en producir y crecer.',
  },
] as const
---

<section id="problema" class="bg-primary py-16 sm:py-24">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <h2 class="text-3xl sm:text-4xl font-bold text-white text-center mb-12">
      El problema que enfrenta tu operación hoy
    </h2>

    <div class="grid sm:grid-cols-2 gap-5">
      {problems.map((item) => (
        <div
          class="flex items-start gap-4 p-6 rounded-lg"
          style="background: rgba(255,255,255,0.06)"
        >
          <div
            class="w-12 h-12 flex items-center justify-center rounded-lg shrink-0"
            style="background: rgba(255,255,255,0.12)"
          >
            <Icon name={`lucide:${item.icon}`} class="w-6 h-6 text-white" />
          </div>
          <div>
            <h3 class="font-semibold text-white mb-1">{item.title}</h3>
            <p class="text-sm text-white/70 leading-relaxed">{item.desc}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
