---
import { Icon } from 'astro-icon/components';
import { PROBLEMS } from '@utils/constants';
---

<section id="problema" class="bg-primary py-16 sm:py-24">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <h2 class="mb-12 text-center text-3xl font-bold text-white sm:text-4xl">
      El problema que enfrenta tu operación hoy
    </h2>

    <div class="grid gap-5 sm:grid-cols-2">
      {
        PROBLEMS.map((item) => (
          <div
            class="flex items-start gap-4 rounded-lg p-6"
            style="background: rgba(255,255,255,0.06)"
          >
            <div
              class="flex h-12 w-12 shrink-0 items-center justify-center rounded-lg"
              style="background: rgba(255,255,255,0.12)"
            >
              <Icon name={`lucide:${item.icon}`} class="h-6 w-6 text-white" />
            </div>
            <div>
              <h3 class="mb-1 font-semibold text-white">{item.title}</h3>
              <p class="text-sm leading-relaxed text-white/70">{item.desc}</p>
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>
