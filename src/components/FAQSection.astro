---
import Eyebrow from '@atoms/Eyebrow.astro';
import { Icon } from 'astro-icon/components';

const qs = [
  {
    q: '¿Cuánto demora poner mi finca en TerraCore?',
    a: 'En marcha en tu primera semana. Importas tu inventario desde Excel, defines usuarios y arrancas. Si tu operación es grande, te acompañamos con sesiones de onboarding hasta que estés cómodo.',
  },
  {
    q: '¿Funciona si en mi finca no hay buena señal?',
    a: 'Sí. La app móvil guarda todo lo que registres sin internet y sincroniza cuando vuelva la señal. El dashboard web requiere conexión, pero los registros del campo nunca se pierden.',
  },
  {
    q: '¿Puedo migrar desde Excel?',
    a: 'Sí. Tenemos plantillas de importación para animales, insumos, herramientas e historiales sanitarios. La migración está incluida en planes Profesional y Enterprise. En Semilla te damos las plantillas y lo haces tú mismo.',
  },
  {
    q: '¿Qué tipos de finca soporta?',
    a: 'Si produces en ella, TerraCore lo registra. Bovino (carne y leche), porcino, equino, ovino, caprino, avícola y cultivos asociados como plátano, cacao y maíz. Si tu operación combina varios, mejor, todo queda en el mismo lugar.',
  },
  {
    q: '¿Qué pasa con mis datos si dejo de usar TerraCore?',
    a: 'Te entregamos un export completo en CSV en máximo 48 horas y borramos tu información de nuestros servidores. Sin trampas, sin "datos rehén".',
  },
  {
    q: '¿Tiene aplicación móvil?',
    a: 'TerraCore es una PWA (Progressive Web App) optimizada para mobile. La instalas desde el navegador en Android o iOS, sin pasar por el App Store. Funciona offline, con botones grandes y captura rápida pensada para usarla en el campo.',
  },
];
---

<section class="section-pad" id="faq">
  <div class="container">
    <div class="faq-wrap">
      <div>
        <Eyebrow num="06">Preguntas</Eyebrow>
        <h2 class="display lg" style="margin-top:16px; margin-bottom:16px">
          Las dudas<br />que siempre nos hacen.
        </h2>
        <p class="lead">
          ¿No ves la tuya? Escríbenos a{' '}
          <a href="mailto:hola@terracoreapp.co" class="faq-link">hola@terracoreapp.co</a>{' '}
          y te respondemos en menos de un día hábil.
        </p>
      </div>

      <div class="faq-list">
        {
          qs.map((it) => (
            <div class="faq-item" data-faq>
              <button class="faq-q" aria-expanded="false">
                <span>{it.q}</span>
                <span class="faq-plus" aria-hidden="true">
                  <Icon name="lucide:plus" width={14} height={14} />
                </span>
              </button>
              <div class="faq-a">
                <div class="faq-a-inner">{it.a}</div>
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </div>
</section>

<script>
  const items = document.querySelectorAll<HTMLElement>('[data-faq]');

  function closeItem(el: HTMLElement) {
    el.classList.remove('faq-item--open');
    const b = el.querySelector<HTMLButtonElement>('.faq-q')!;
    const a = el.querySelector<HTMLElement>('.faq-a')!;
    b.setAttribute('aria-expanded', 'false');
    a.style.height = '0';
  }

  items.forEach((item) => {
    const btn = item.querySelector<HTMLButtonElement>('.faq-q')!;
    const answer = item.querySelector<HTMLElement>('.faq-a')!;
    btn.addEventListener('click', () => {
      const isOpen = btn.getAttribute('aria-expanded') === 'true';
      items.forEach(closeItem);
      if (!isOpen) {
        item.classList.add('faq-item--open');
        btn.setAttribute('aria-expanded', 'true');
        answer.style.height = answer.scrollHeight + 'px';
      }
    });
  });
</script>

<style>
  .faq-wrap {
    display: grid;
    grid-template-columns: 1fr 1.4fr;
    gap: 64px;
  }
  @media (max-width: 880px) {
    .faq-wrap {
      grid-template-columns: 1fr;
      gap: 32px;
    }
  }

  .faq-link {
    color: var(--color-accent);
    font-weight: 600;
  }
  .faq-link:hover {
    color: var(--color-accent-hover);
  }

  .faq-list {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .faq-item {
    border-bottom: 1px solid var(--color-border);
  }

  .faq-q {
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 24px 0;
    font-size: 17px;
    font-weight: 600;
    color: var(--color-text);
    font-family: var(--font-display);
    letter-spacing: -0.01em;
    text-align: left;
    gap: 16px;
    cursor: pointer;
    transition: color var(--dur-base) var(--ease-standard);
  }
  .faq-q:hover {
    color: var(--color-primary);
  }

  .faq-plus {
    width: 28px;
    height: 28px;
    border-radius: 999px;
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    display: flex;
    align-items: center;
    justify-content: center;
    flex: 0 0 auto;
    transition: all var(--dur-base) var(--ease-standard);
  }
  .faq-item--open .faq-plus {
    background: var(--color-primary);
    color: #fff;
    border-color: var(--color-primary);
    transform: rotate(45deg);
  }

  .faq-a {
    overflow: hidden;
    height: 0;
    transition: height 240ms ease-out;
  }
  .faq-a-inner {
    padding-bottom: 24px;
    font-size: 15px;
    line-height: 24px;
    color: var(--color-text-secondary);
    max-width: 64ch;
  }
</style>
