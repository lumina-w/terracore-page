---
import { FAQ } from '@utils/constants'
---

<section class="bg-background py-16 sm:py-24">
  <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8">
    <h2 class="text-3xl sm:text-4xl font-bold text-primary text-center mb-12">
      Preguntas frecuentes
    </h2>

    <div class="flex flex-col divide-y divide-border">
      {FAQ.map((item) => (
        <div class="py-6">
          <h3 class="text-base font-semibold text-foreground mb-2">{item.q}</h3>
          <p class="text-muted-foreground leading-relaxed">{item.a}</p>
        </div>
      ))}
    </div>
  </div>
</section>
