---
import { Icon } from 'astro-icon/components';

const ctaUrl = import.meta.env.MAIN_CTA_URL ?? 'https://calendly.com/wavival/30min';
---

<section class="cta-band reveal" id="demo">
  <div class="container">
    <div class="cta-card marker-corners" style="color:rgba(255,255,255,0.4)">
      <div class="cta-card__main">
        <h2 class="cta-card__heading">
          Tu finca, ordenada.<br /><span class="accent-line">En menos de una semana.</span>
        </h2>
        <p class="cta-card__desc">
          Agenda una demo de 30 minutos. Te mostramos TerraCore con datos de fincas reales y
          resolvemos tus dudas sin compromiso.
        </p>
        <div class="cta-actions">
          <a href={ctaUrl} target="_blank" rel="noopener noreferrer" class="btn btn-accent" onclick="window.trackEvent?.('click_cta_main')">
            Agenda demo gratis
            <Icon name="lucide:arrow-right" width={16} height={16} />
          </a>
          <a href="https://wa.me/573108283088?text=Quiero%20solicitar%20una%20demo%20de%20TerraCore%20para%20mi%20finca" target="_blank" class="btn btn-ghost-dark">
            Hablar por WhatsApp
          </a>
        </div>
      </div>

      <div class="cta-side">
        <div class="cta-side__label">Lo que pasa después</div>
        <ul class="cta-side__list">
          <li>
            <span class="check-wrap"><Icon name="lucide:check" width={14} height={14} /></span>
            Llamada de 30 minutos con tu equipo
          </li>
          <li>
            <span class="check-wrap"><Icon name="lucide:check" width={14} height={14} /></span>
            Demo personalizada con tus datos
          </li>
          <li>
            <span class="check-wrap"><Icon name="lucide:check" width={14} height={14} /></span>
            Plan de migración sin costo
          </li>
          <li>
            <span class="check-wrap"><Icon name="lucide:check" width={14} height={14} /></span>
            Prueba de 14 días, sin tarjeta
          </li>
        </ul>
      </div>
    </div>
  </div>
</section>

<script>
  const side = document.querySelector('.cta-side');
  if (side) {
    const observer = new IntersectionObserver(
      ([entry]) => {
        if (entry.isIntersecting) {
          side.classList.add('cta-side--visible');
          observer.disconnect();
        }
      },
      { threshold: 0.25 },
    );
    observer.observe(side);
  }
</script>

<style>
  .accent-line {
    color: var(--color-accent);
  }

  .cta-band {
    background: var(--color-bg);
    padding: 96px 0;
  }

  .cta-card {
    background: var(--color-primary-active);
    border-radius: 20px;
    padding: 64px;
    color: #fff;
    position: relative;
    overflow: hidden;
    display: grid;
    grid-template-columns: 1.3fr 1fr;
    gap: 48px;
    align-items: center;
  }
  .cta-card::before {
    content: '';
    position: absolute;
    inset: 0;
    background:
      radial-gradient(500px 400px at 100% 0%, rgba(217, 119, 6, 0.32), transparent 60%),
      radial-gradient(500px 400px at 0% 100%, rgba(60, 117, 86, 0.5), transparent 60%);
    pointer-events: none;
  }
  .cta-card > * {
    position: relative;
  }

  .cta-card__heading {
    color: #fff;
    font-family: var(--font-display);
    font-size: clamp(32px, 4vw, 52px);
    font-weight: 700;
    letter-spacing: -0.025em;
    line-height: 1.05;
    margin: 0 0 16px;
    text-wrap: balance;
  }
  .cta-card__desc {
    color: rgba(255, 255, 255, 0.78);
    font-size: 17px;
    line-height: 26px;
    max-width: 50ch;
    margin: 0 0 28px;
  }
  .cta-actions {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
  }

  /* Side card */
  .cta-side {
    background: rgba(0, 0, 0, 0.22);
    border: 1px solid rgba(255, 255, 255, 0.18);
    border-radius: 16px;
    padding: 28px;
    box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.08);
  }
  .cta-side__label {
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-accent);
    margin-bottom: 18px;
  }
  .cta-side__list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 14px;
  }

  /* List item animation */
  .cta-side__list li {
    display: flex;
    align-items: center;
    gap: 12px;
    font-size: 14px;
    font-weight: 500;
    color: #fff;
    opacity: 0;
    transform: translateY(10px);
    transition:
      opacity 0.4s ease,
      transform 0.4s ease;
  }
  .cta-side--visible .cta-side__list li:nth-child(1) {
    opacity: 1;
    transform: none;
    transition-delay: 0ms;
  }
  .cta-side--visible .cta-side__list li:nth-child(2) {
    opacity: 1;
    transform: none;
    transition-delay: 150ms;
  }
  .cta-side--visible .cta-side__list li:nth-child(3) {
    opacity: 1;
    transform: none;
    transition-delay: 300ms;
  }
  .cta-side--visible .cta-side__list li:nth-child(4) {
    opacity: 1;
    transform: none;
    transition-delay: 450ms;
  }

  /* Check icon wrapper + animation */
  .check-wrap {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 22px;
    height: 22px;
    border-radius: 50%;
    background: rgba(217, 119, 6, 0.18);
    flex: 0 0 auto;
    transform: scale(0);
    transition: transform 0.35s cubic-bezier(0.34, 1.56, 0.64, 1);
  }
  .check-wrap :global(svg) {
    color: var(--color-accent);
  }

  .cta-side--visible .cta-side__list li:nth-child(1) .check-wrap {
    transform: scale(1);
    transition-delay: 60ms;
  }
  .cta-side--visible .cta-side__list li:nth-child(2) .check-wrap {
    transform: scale(1);
    transition-delay: 210ms;
  }
  .cta-side--visible .cta-side__list li:nth-child(3) .check-wrap {
    transform: scale(1);
    transition-delay: 360ms;
  }
  .cta-side--visible .cta-side__list li:nth-child(4) .check-wrap {
    transform: scale(1);
    transition-delay: 510ms;
  }

  @media (max-width: 880px) {
    .cta-card {
      grid-template-columns: 1fr;
      padding: 40px;
    }
  }
  @media (max-width: 720px) {
    .cta-band {
      padding: 64px 0;
    }
  }
</style>
