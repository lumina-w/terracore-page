---
import TerraLogo from '@atoms/TerraLogo.astro';

interface Props {
  mono?: boolean;
  size?: number;
  showCaption?: boolean;
}
const { mono = false, size = 28, showCaption = true } = Astro.props;
---
<div class:list={['brand', mono && 'brand--mono']}>
  <TerraLogo {size} {mono} />
  <div>
    <span class="brand__name">TerraCore</span>
    {showCaption && <span class="brand__caption">Campo inteligente</span>}
  </div>
</div>

<style>
  .brand {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 18px;
    letter-spacing: -0.01em;
    color: var(--color-text);
  }
  .brand--mono { color: #fff; }

  .brand__name { display: block; line-height: 1; }

  .brand__caption {
    display: block;
    font-family: var(--font-sans);
    font-size: 9px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-accent);
    font-weight: 600;
    margin-top: 1px;
  }
</style>
