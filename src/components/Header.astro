---
import Button from './Button.astro'

const ctaUrl = import.meta.env.MAIN_CTA_URL ?? '#'
---

<header class="sticky top-0 z-50 w-full border-b border-border bg-background/80 backdrop-blur-sm">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 h-16 flex items-center justify-between">

    <a href="/" class="flex items-center gap-2 font-bold text-xl text-primary" aria-label="Ir al inicio de TerraCore">
      <svg width="28" height="28" viewBox="0 0 28 28" fill="none" aria-hidden="true" focusable="false">
        <rect width="28" height="28" rx="6" fill="currentColor" />
        <polygon points="14,5 23,14 14,23 5,14" fill="white" opacity="0.9" />
      </svg>
      TerraCore
    </a>

    <Button href={ctaUrl} variant="primary" size="sm">Agendar demo</Button>
  </div>
</header>
