---
import Button from './Button.astro'

const ctaUrl = import.meta.env.MAIN_CTA_URL ?? '#'
---

<section
  class="relative isolate min-h-[100dvh] flex flex-col items-center justify-center text-center px-4 sm:px-6 lg:px-8 py-24 overflow-hidden"
>
  <!-- Background decoration -->
  <div
    class="absolute inset-0 -z-10 pointer-events-none"
    aria-hidden="true"
    style="background: radial-gradient(ellipse 90% 60% at 50% -5%, rgba(27,67,50,0.09) 0%, transparent 70%)"
  ></div>

  <div class="max-w-4xl mx-auto flex flex-col items-center gap-8">
    <!-- Badge -->
    <div
      class="inline-flex items-center gap-2 px-4 py-1.5 rounded-pill text-primary text-sm font-medium"
      style="background: rgba(27,67,50,0.07); border: 1px solid rgba(27,67,50,0.18)"
    >
      <span aria-hidden="true">🌿</span>
      Plataforma SaaS agroindustrial · Colombia
    </div>

    <!-- Headline -->
    <h1 class="text-3xl sm:text-5xl lg:text-6xl font-bold text-primary leading-tight">
      Ten el control total de tu operación,
      <span class="text-accent"> antes de que algo salga mal</span>
    </h1>

    <!-- Subheadline -->
    <p class="max-w-2xl text-lg sm:text-xl text-muted-foreground leading-relaxed">
      Todos tus datos en un solo lugar. Alertas en tiempo real. Cero sorpresas
      en inventario, personal o salud animal.
    </p>

    <!-- CTAs -->
    <div class="flex flex-col sm:flex-row gap-3 w-full sm:w-auto">
      <Button
        href={ctaUrl}
        variant="primary"
        size="lg"
        onclick="window.trackEvent('click_cta_hero')"
        class="w-full sm:w-auto"
      >
        Agendar demo
      </Button>
      <Button href="#problema" variant="secondary" size="lg" class="w-full sm:w-auto">
        Ver cómo funciona
      </Button>
    </div>
  </div>

  <!-- Scroll hint -->
  <div class="absolute bottom-8 left-1/2 -translate-x-1/2 flex flex-col items-center gap-1.5 text-muted-foreground text-xs select-none">
    <span>Scroll</span>
    <svg
      class="w-4 h-4 animate-bounce"
      fill="none"
      viewBox="0 0 24 24"
      stroke="currentColor"
      stroke-width="2"
      aria-hidden="true"
    >
      <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
    </svg>
  </div>
</section>
