---
import { Icon } from 'astro-icon/components';

interface Props {
  /** WhatsApp fallback link (wa.me/...) shown below the form */
  whatsappUrl?: string;
}

const {
  whatsappUrl = 'https://wa.me/573108283088?text=Quiero%20solicitar%20una%20demo%20de%20TerraCore%20para%20mi%20finca',
} = Astro.props;
---

<div class="lead" data-lead>
  <form class="lead-form" data-lead-form novalidate>
    <p class="lead-intro">
      Cuéntanos sobre tu operación, te ayudaremos a encontrar el plan perfecto.
    </p>

    <div class="form-cols">
      <div class="form-col">
        <fieldset class="field group--personal group">
          <legend
            ><span class="legend-text">Información personal <span class="req">*</span></span
            ></legend
          >
          <div class="field field--text">
            <label for="lead-nombre">Nombre completo <span class="req">*</span></label>
            <input
              id="lead-nombre"
              name="nombre"
              type="text"
              required
              autocomplete="name"
              autocapitalize="words"
              spellcheck="false"
              enterkeyhint="next"
              placeholder="Ej: Juan Pérez"
            />
          </div>

          <div class="field field--text">
            <label for="lead-email">Email <span class="req">*</span></label>
            <input
              id="lead-email"
              name="email"
              type="email"
              required
              autocomplete="email"
              inputmode="email"
              spellcheck="false"
              enterkeyhint="next"
              placeholder="Ej: juan@tufinca.co"
            />
          </div>

          <div class="field field--text">
            <label for="lead-whatsapp">WhatsApp <span class="req">*</span></label>
            <input
              id="lead-whatsapp"
              name="whatsapp"
              type="tel"
              required
              autocomplete="tel"
              inputmode="tel"
              enterkeyhint="next"
              placeholder="Ej: 300 000 0000"
            />
          </div>
        </fieldset>

        <fieldset class="field group--empresa group">
          <legend
            ><span class="legend-text">Sobre tu operación <span class="req">*</span></span></legend
          >
          <div class="field field--text">
            <label for="lead-empresa">Empresa o finca <span class="req">*</span></label>
            <input
              id="lead-empresa"
              name="empresa"
              type="text"
              required
              autocomplete="organization"
              autocapitalize="words"
              enterkeyhint="next"
              placeholder="Ej: Hacienda La Esperanza"
            />
          </div>

          <div class="field field--text">
            <label for="lead-region">Región <span class="req">*</span></label>
            <input
              id="lead-region"
              name="region"
              type="text"
              required
              autocomplete="address-level1"
              autocapitalize="words"
              enterkeyhint="next"
              placeholder="Ej: Antioquia"
            />
          </div>
        </fieldset>
      </div>

      <div class="form-col">
        <fieldset class="field group--tamano group">
          <legend
            ><span class="legend-text">Tamaño de operación <span class="req">*</span></span></legend
          >
          <div class="options">
            <label class="opt">
              <input
                type="radio"
                name="tamano_operacion"
                value="Pequeña (1 sede, hasta 5 personas)"
                required
              />
              <span class="opt-mark" aria-hidden="true"></span>
              <span class="opt-label">Pequeña (1 sede, hasta 5 personas)</span>
            </label>
            <label class="opt">
              <input
                type="radio"
                name="tamano_operacion"
                value="Mediana (2 a 3 sedes, hasta 15 personas)"
                required
              />
              <span class="opt-mark" aria-hidden="true"></span>
              <span class="opt-label">Mediana (2 a 3 sedes, hasta 15 personas)</span>
            </label>
            <label class="opt">
              <input
                type="radio"
                name="tamano_operacion"
                value="Grande (varias sedes o grupo empresarial)"
                required
              />
              <span class="opt-mark" aria-hidden="true"></span>
              <span class="opt-label">Grande (varias sedes o grupo empresarial)</span>
            </label>
          </div>
        </fieldset>

        <fieldset class="field group--consulta group">
          <legend
            ><span class="legend-text">Tipo de consulta <span class="req">*</span></span></legend
          >
          <div class="options">
            <label class="opt">
              <input type="radio" name="tipo_consulta" value="Ventas" required checked />
              <span class="opt-mark" aria-hidden="true"></span>
              <span class="opt-label">Ventas (quiero conocer planes y precios)</span>
            </label>
            <label class="opt">
              <input type="radio" name="tipo_consulta" value="Soporte técnico" required />
              <span class="opt-mark" aria-hidden="true"></span>
              <span class="opt-label">Soporte técnico (ya soy cliente)</span>
            </label>
          </div>
        </fieldset>
      </div>
    </div>

    <button type="submit" class="btn btn-accent lead-submit" data-lead-submit disabled>
      <span data-submit-label>Quiero mi diagnóstico gratis</span>
      <Icon name="lucide:arrow-right" width={16} height={16} aria-hidden="true" />
    </button>

    <p class="lead-error" data-lead-error role="alert" hidden>
      Algo salió mal. Intenta de nuevo o escríbenos directo por WhatsApp.
    </p>

    <div class="lead-divider" aria-hidden="true">
      <span>¿Prefieres escribir directo?</span>
    </div>
    <a href={whatsappUrl} target="_blank" rel="noopener noreferrer" class="btn btn-ghost-dark">
      Hablar por WhatsApp
      <Icon name="simple-icons:whatsapp" width={18} height={18} aria-hidden="true" />
      <span class="sr-only">(abre en una pestaña nueva)</span>
    </a>
  </form>

  <div class="lead-success" data-lead-success role="status" hidden>
    <div class="lead-success__check" aria-hidden="true">
      <Icon name="lucide:check" width={28} height={28} />
    </div>
    <h3 tabindex="-1" data-success-heading>¡Listo, <span data-success-name>!</span></h3>
    <p>
      Te contactamos por WhatsApp o correo pronto.<br />
      Mientras tanto, si tienes una pregunta urgente:
    </p>
    <a href={whatsappUrl} target="_blank" rel="noopener noreferrer" class="btn btn-accent">
      Hablar por WhatsApp
      <Icon name="simple-icons:whatsapp" width={18} height={18} aria-hidden="true" />
      <span class="sr-only">(abre en una pestaña nueva)</span>
    </a>
  </div>
</div>

<script>
  const SUPABASE_URL = import.meta.env.PUBLIC_SUPABASE_URL;
  const SUPABASE_ANON_KEY = import.meta.env.PUBLIC_SUPABASE_ANON_KEY;

  const root = document.querySelector<HTMLElement>('[data-lead]');
  const form = root?.querySelector<HTMLFormElement>('[data-lead-form]');
  const submitBtn = form?.querySelector<HTMLButtonElement>('[data-lead-submit]');
  const submitLabel = form?.querySelector<HTMLElement>('[data-submit-label]');
  const errorEl = form?.querySelector<HTMLElement>('[data-lead-error]');
  const successEl = root?.querySelector<HTMLElement>('[data-lead-success]');
  const successName = successEl?.querySelector<HTMLElement>('[data-success-name]');

  if (form && submitBtn && submitLabel && errorEl && successEl) {
    const defaultLabel = submitLabel.textContent ?? 'Quiero mi diagnóstico gratis';

    // Enable submit only when every required field is valid
    const syncSubmitState = () => {
      if (submitLabel.textContent === 'Enviando…') return;
      submitBtn.disabled = !form.checkValidity();
    };
    form.addEventListener('input', syncSubmitState);
    form.addEventListener('change', syncSubmitState);
    syncSubmitState();

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      if (!form.reportValidity()) return;

      errorEl.hidden = true;
      submitBtn.disabled = true;
      form.setAttribute('aria-busy', 'true');
      submitLabel.textContent = 'Enviando…';

      const data = new FormData(form);
      const nombre = String(data.get('nombre') ?? '').trim();
      const payload = {
        nombre,
        email: String(data.get('email') ?? '').trim(),
        whatsapp: String(data.get('whatsapp') ?? '').trim(),
        empresa: String(data.get('empresa') ?? '').trim(),
        region: String(data.get('region') ?? '').trim(),
        tamano_operacion: String(data.get('tamano_operacion') ?? ''),
        tipo_consulta: String(data.get('tipo_consulta') ?? ''),
        fuente: 'landing-terracore',
      };

      try {
        if (!SUPABASE_URL || !SUPABASE_ANON_KEY) throw new Error('Supabase env missing');

        const res = await fetch(`${SUPABASE_URL}/rest/v1/terracore_leads`, {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
            apikey: SUPABASE_ANON_KEY,
            Authorization: `Bearer ${SUPABASE_ANON_KEY}`,
            Prefer: 'return=minimal',
          },
          body: JSON.stringify(payload),
        });

        if (!res.ok) throw new Error(`Supabase ${res.status}`);

        window.trackEvent?.('submit_lead', {
          tipo_consulta: payload.tipo_consulta,
          tamano_operacion: payload.tamano_operacion,
        });

        if (successName) successName.textContent = `${nombre}!`;
        form.removeAttribute('aria-busy');
        form.hidden = true;
        successEl.hidden = false;
        successEl.scrollIntoView({ behavior: 'smooth', block: 'center' });
        const heading = successEl.querySelector<HTMLElement>('[data-success-heading]');
        heading?.focus();
      } catch {
        errorEl.hidden = false;
        form.removeAttribute('aria-busy');
        submitBtn.disabled = false;
        submitLabel.textContent = defaultLabel;
      }
    });
  }
</script>

<style>
  /* ── Card shell ─────────────────────────────────────────────
     The form lives on a dark section. We give it a subtle elevated
     "panel" treatment so it reads as a designed surface, not a bare
     stack of inputs. */
  .lead {
    max-width: 560px;
    background: linear-gradient(180deg, rgba(255, 255, 255, 0.055), rgba(255, 255, 255, 0.02));
    border: 1px solid rgba(255, 255, 255, 0.12);
    border-radius: 20px;
    padding: 28px;
    box-shadow:
      0 24px 64px rgba(13, 42, 31, 0.45),
      inset 0 1px 0 rgba(255, 255, 255, 0.06);
  }

  .lead-form {
    display: flex;
    flex-direction: column;
    gap: 22px;
  }

  /* Short intro line above the fields */
  .lead-intro {
    margin: 0;
    font-size: 15px;
    line-height: 1.5;
    color: rgba(255, 255, 255, 0.78);
  }

  /* Each column is a vertical stack of full fields */
  .form-cols {
    display: flex;
    flex-direction: column;
    gap: 22px;
  }
  .form-col {
    display: flex;
    flex-direction: column;
    gap: 22px;
    min-width: 0;
  }

  /* Wider padded panel from tablet up (still single column) */
  @media (min-width: 768px) {
    .lead {
      max-width: 820px;
      padding: 40px;
    }
  }

  /* ── 2-column layout (desktop only) ──────────────────────────
     Two side-by-side columns, each a vertical stack of whole fields.
     Tablet and mobile stay single column. */
  @media (min-width: 1024px) {
    .form-cols {
      flex-direction: row;
      align-items: start;
      gap: 32px;
    }
    .form-col {
      flex: 1 1 0;
    }
  }

  /* ── Field base ─────────────────────────────────────────────── */
  .field {
    display: flex;
    flex-direction: column;
    gap: 9px;
    border: 0;
    padding: 0;
    margin: 0;
    min-width: 0;
  }

  /* Input labels: refined, uppercase micro-label rhythm */
  .field--text > label {
    font-family: var(--font-sans);
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.62);
    padding: 0;
    margin: 0;
  }

  .req {
    color: var(--tc-amber-400);
    font-weight: 700;
  }

  /* ── Text inputs / textarea ─────────────────────────────────── */
  .field input[type='text'],
  .field input[type='tel'],
  .field input[type='email'],
  .field textarea {
    width: 100%;
    font-family: var(--font-sans);
    font-size: 15px;
    line-height: 1.45;
    color: #fff;
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid rgba(255, 255, 255, 0.16);
    border-radius: 12px;
    padding: 13px 15px;
    transition:
      border-color var(--dur-base) var(--ease-standard),
      box-shadow var(--dur-base) var(--ease-standard),
      background var(--dur-base) var(--ease-standard);
  }
  .field textarea {
    resize: vertical;
    min-height: 96px;
  }
  .field input::placeholder,
  .field textarea::placeholder {
    color: rgba(255, 255, 255, 0.38);
  }
  .field input:hover,
  .field textarea:hover {
    border-color: rgba(255, 255, 255, 0.28);
    background: rgba(255, 255, 255, 0.07);
  }
  .field input:focus,
  .field textarea:focus {
    outline: none;
    background: rgba(255, 255, 255, 0.1);
    border-color: var(--color-accent);
    box-shadow: 0 0 0 3px rgba(217, 119, 6, 0.3);
  }

  /* ── Question groups (radio "checklists") ───────────────────── */
  .group {
    gap: 14px;
  }

  /* Distinct, larger, divider-style legend with an accent marker */
  .group > legend {
    width: 100%;
    padding: 0;
    margin: 0 0 8px;
  }
  .group > legend .legend-text {
    display: inline-flex;
    align-items: center;
    gap: 11px;
    font-family: var(--font-display);
    font-size: 19px;
    font-weight: 700;
    letter-spacing: -0.01em;
    color: #fff;
  }
  /* Accent marker bar before each group heading */
  .group > legend .legend-text::before {
    content: '';
    width: 4px;
    height: 19px;
    border-radius: 999px;
    background: var(--color-accent);
    flex: 0 0 auto;
  }

  /* Each group lives in one of the two form columns, so options stack
     as single full-width rows. */
  .options {
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  /* Selectable tile — a real radio input, styled as a checklist row */
  .opt {
    position: relative;
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 13px 15px;
    border: 1px solid rgba(255, 255, 255, 0.14);
    border-radius: 12px;
    background: rgba(255, 255, 255, 0.035);
    font-size: 14px;
    font-weight: 500;
    color: rgba(255, 255, 255, 0.82);
    cursor: pointer;
    transition:
      border-color var(--dur-base) var(--ease-standard),
      background var(--dur-base) var(--ease-standard),
      color var(--dur-base) var(--ease-standard),
      box-shadow var(--dur-base) var(--ease-standard);
  }
  .opt:hover {
    border-color: rgba(255, 255, 255, 0.3);
    background: rgba(255, 255, 255, 0.06);
    color: #fff;
  }

  /* Visually hidden native input — keeps a11y + form value intact */
  .opt input {
    position: absolute;
    opacity: 0;
    width: 1px;
    height: 1px;
    margin: 0;
    pointer-events: none;
  }

  /* Custom radio dot */
  .opt-mark {
    flex: 0 0 auto;
    width: 19px;
    height: 19px;
    border-radius: 50%;
    border: 2px solid rgba(255, 255, 255, 0.4);
    background: transparent;
    transition:
      border-color var(--dur-base) var(--ease-standard),
      box-shadow var(--dur-base) var(--ease-standard);
    position: relative;
  }
  .opt-mark::after {
    content: '';
    position: absolute;
    inset: 50%;
    width: 9px;
    height: 9px;
    border-radius: 50%;
    background: var(--color-accent);
    transform: translate(-50%, -50%) scale(0);
    transition: transform var(--dur-base) var(--ease-emphasized);
  }
  .opt-label {
    line-height: 1.35;
  }

  /* Selected state */
  .opt:has(input:checked) {
    border-color: var(--color-accent);
    background: rgba(217, 119, 6, 0.14);
    color: #fff;
  }
  .opt:has(input:checked) .opt-mark {
    border-color: var(--color-accent);
  }
  .opt:has(input:checked) .opt-mark::after {
    transform: translate(-50%, -50%) scale(1);
  }

  /* Keyboard focus ring on the tile */
  .opt:has(input:focus-visible) {
    border-color: var(--color-accent);
    box-shadow: 0 0 0 3px rgba(217, 119, 6, 0.3);
  }

  /* ── Submit ─────────────────────────────────────────────────── */
  .lead-submit {
    margin-top: 2px;
    justify-content: center;
    width: 100%;
    padding: 16px 22px;
    font-size: 16px;
    border-radius: 12px;
    box-shadow: 0 10px 24px rgba(217, 119, 6, 0.32);
  }
  .lead-submit:disabled {
    opacity: 0.45;
    cursor: not-allowed;
    box-shadow: none;
  }
  .lead-submit:disabled:hover {
    transform: none;
  }

  /* ── Error ──────────────────────────────────────────────────── */
  .lead-error {
    margin: 0;
    font-size: 13px;
    font-weight: 500;
    color: #ffd9b3;
    background: rgba(217, 119, 6, 0.16);
    border: 1px solid rgba(217, 119, 6, 0.4);
    border-radius: 12px;
    padding: 12px 14px;
  }

  /* ── "Or write directly" divider ────────────────────────────── */
  .lead-divider {
    display: flex;
    align-items: center;
    gap: 14px;
    margin: 2px 0;
    color: rgba(255, 255, 255, 0.55);
    font-size: 13px;
  }
  .lead-divider::before,
  .lead-divider::after {
    content: '';
    flex: 1;
    height: 1px;
    background: rgba(255, 255, 255, 0.12);
  }
  .lead-divider span {
    flex: 0 0 auto;
  }

  .lead-form > .btn-ghost-dark {
    width: 100%;
    justify-content: center;
    padding: 14px 22px;
    border-radius: 12px;
  }
  .lead-form > .btn-ghost-dark :global(svg) {
    color: #25d366;
  }

  /* ── Success state ──────────────────────────────────────────── */
  .lead-success {
    text-align: center;
    padding: 16px 0;
  }
  .lead-success__check {
    width: 60px;
    height: 60px;
    border-radius: 50%;
    background: rgba(217, 119, 6, 0.18);
    border: 1px solid rgba(217, 119, 6, 0.45);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 18px;
  }
  .lead-success__check :global(svg) {
    color: var(--color-accent);
  }
  .lead-success h3 {
    font-family: var(--font-display);
    font-size: 26px;
    font-weight: 700;
    color: #fff;
    margin: 0 0 10px;
  }
  .lead-success p {
    font-size: 15px;
    line-height: 24px;
    color: rgba(255, 255, 255, 0.78);
    margin: 0 0 22px;
  }

  /* ── Reduced motion ─────────────────────────────────────────── */
  @media (prefers-reduced-motion: reduce) {
    .opt-mark::after {
      transition: none;
    }
  }
</style>
